---
import { useTranslations, type Lang } from "@/utils/i18n";

interface Props {
	lang?: Lang;
}

const lang = Astro.props.lang ?? "zh";
const t = useTranslations(lang).speaker;
const prefix = lang === "en" ? "/2026/en" : "/2026";

const speakers = [
	{
		name: {
			zh: "李雪莉",
			en: "Shirley Li"
		},
		desc: {
			zh: "《報導者》營運長、臺大新聞所兼任副教授",
			en: "COO of The Reporter and adjunct associate professor at NTU"
		},
		img: "/2026/img/guest/李雪莉.webp"
	},
	{
		name: {
			zh: "蔡嘉平",
			en: "Chia-Ping Tsai"
		},
		desc: {
			zh: "Apache 核心維護者",
			en: "Apache core maintainer"
		},
		img: "/2026/img/guest/蔡嘉平.webp"
	},
	{
		name: {
			zh: "蕭上農 fOx",
			en: "Fox Hsiao"
		},
		desc: {
			zh: "愛料理 / INSIDE 創辦人",
			en: "Founder of iCook and INSIDE"
		},
		img: "/2026/img/guest/蕭上農.webp"
	},
	{
		name: {
			zh: "趙式隆",
			en: "Jack Chao"
		},
		desc: {
			zh: "臺北市政府資訊局局長",
			en: "Commissioner of Taipei City Department of Information Technology"
		},
		img: "/2026/img/guest/趙式隆.webp"
	},
	{
		name: {
			zh: "李比鄰",
			en: "Billion Lee"
		},
		desc: {
			zh: "Cofacts 共同發起人",
			en: "Co-founder of Cofacts"
		},
		img: "/2026/img/guest/李比鄰.webp"
	},
	{
		name: {
			zh: "葉浩",
			en: "Hao Yeh"
		},
		desc: {
			zh: "國立政治大學政治學系教授",
			en: "Professor of Political Science at National Chengchi University"
		},
		img: "/2026/img/guest/葉浩.webp"
	}
];
---

<section class="speaker-section">
	<div class="title">
		<h2 class="text-reveal-title">{t.title1}</h2>
		<div class="line"></div>
		<h2 class="text-reveal-title">{t.title2}</h2>
	</div>

	<div class="content-wrapper">
		<div class="speaker-list">
			{
				speakers.map((person, index) => (
					<div class:list={["speaker-item", { active: index === 0 }]} data-img={person.img} data-alt={person.name[lang]}>
						<h3 class="text-reveal-title">{person.name[lang]}</h3>
						<p class="speakerdesc">{person.desc[lang]}</p>
					</div>
				))
			}
		</div>

		<div class="speaker-image">
			<img id="speaker-img" class="desktop-img" src={speakers[0].img} alt={speakers[0].name[lang]} />

			<div class="marquee-container">
				<div class="marquee-track">
					{speakers.map(person => <img class="marquee-item" src={person.img} alt={person.name[lang]} />)}
					{speakers.map(person => <img class="marquee-item" src={person.img} alt={person.name[lang]} />)}
				</div>
			</div>
		</div>
	</div>

	<a href={`${prefix}/agenda/`} class="cta-btn">{t.cta}</a>

	<div class="bg-optimized">
		<svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
			<defs>
				<path id="gentle-wave" d="m-160 44c30 0 58-8 88-8s 58 4 88 8 58-8 88-8 58 8 88 8 v44h-352z"></path>
			</defs>
			<g class="parallax">
				<use xlink:href="#gentle-wave" x="48" y="0" fill="rgba(161, 161, 161, 0.34)"></use>
				<use xlink:href="#gentle-wave" x="48" y="3" fill="rgba(217, 217, 217, 0.34)"></use>
				<use xlink:href="#gentle-wave" x="48" y="5" fill="rgba(205, 205, 205, 0.34)"></use>
				<use xlink:href="#gentle-wave" x="48" y="7" fill="#e0e0e0"></use>
			</g>
		</svg>
	</div>
</section>

<style>
	@keyframes scroll {
		0% {
			transform: translatex(0);
		}
		100% {
			transform: translatex(-50%);
		}
	}

	@keyframes move-forever {
		0% {
			transform: translate3d(-5.625rem, 0, 0);
		}
		100% {
			transform: translate3d(5.3125rem, 0, 0);
		}
	}

	.speaker-section {
		position: relative;
		background: radial-gradient(circle at 22% 12%, rgba(242, 216, 148, 0.16), transparent 28rem), linear-gradient(180deg, rgba(20, 19, 15, 0.98), rgba(36, 35, 31, 0.96));
		padding: var(--section-padding);
		display: flex;
		flex-direction: column;
		align-items: center;
		overflow: hidden;
	}

	.title {
		width: 100%;
		max-width: var(--max-width);
		margin-bottom: 3rem;
		color: var(--metal-gold-soft);
		display: grid;
		grid-template-columns: max-content 1fr max-content;
		align-items: center;
		gap: 2rem;
	}

	.line {
		height: 0.0625rem;
		background: linear-gradient(90deg, transparent, var(--metal-line), transparent);
		width: 100%;
		justify-self: center;
	}

	.content-wrapper {
		width: 100%;
		max-width: 65rem;
		display: flex;
		flex-direction: row;
		gap: 2rem;
		align-items: center;
	}

	.speaker-list {
		flex: 1;
		min-width: 0;
	}

	.speaker-item {
		width: 100%;
		font-size: 3.5rem;
		font-weight: bold;
		color: rgba(244, 239, 229, 0.24);
		cursor: pointer;
		transition: 0.3s;
		display: flex;
		flex-direction: row;
		align-items: center;
		text-align: left;
		box-sizing: border-box;
	}

	.speaker-item.active {
		color: var(--metal-cream);
		transform: scale(1.125);
		transform-origin: left center;
	}

	.speakerdesc {
		width: 10rem;
		flex-shrink: 0;
		order: -1;
		font-size: 0.875rem;
		font-weight: normal;
		color: transparent;
		line-height: 1.4;
		text-align: right;
		padding-right: 1rem;
		box-sizing: border-box;
	}

	.speaker-item.active .speakerdesc {
		color: var(--metal-muted);
	}

	.speaker-image {
		width: 22rem;
		flex-shrink: 0;
		perspective: 62.5rem;
	}

	.desktop-img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 0.5rem;
		border: 1px solid rgba(242, 216, 148, 0.18);
		box-shadow: var(--metal-card-shadow);
		transform-style: preserve-3d;
		transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
	}

	.marquee-container {
		display: none;
	}

	.cta-btn {
		display: inline-block;
		text-decoration: none;
		font-family: sans-serif;
		font-weight: 700;
		font-size: 1.5rem;
		letter-spacing: 0.05em;
		color: var(--metal-ink);
		padding: 0.75rem 3rem;
		margin-top: 5rem;
		border: 0.125rem solid rgba(242, 216, 148, 0.6);
		border-radius: 624.9375rem;
		background: linear-gradient(180deg, var(--metal-cream) 0%, var(--metal-gold) 100%);
		transition:
			transform 0.2s,
			filter 0.2s;
	}

	.cta-btn:hover {
		transform: translatey(-0.125rem);
		filter: brightness(1.05);
	}

	.title,
	.content-wrapper,
	.cta-btn {
		position: relative;
		z-index: 1;
	}

	.bg-optimized {
		position: absolute;
		top: auto;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 62%;
		opacity: 0.22;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.waves {
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 100%;
		min-height: 6.25rem;
	}

	.parallax > use {
		animation: move-forever 25s cubic-bezier(0.55, 0.5, 0.45, 0.5) infinite;
	}

	.parallax > use:nth-child(1) {
		animation-delay: -2s;
		animation-duration: 7s;
	}
	.parallax > use:nth-child(2) {
		animation-delay: -3s;
		animation-duration: 10s;
	}
	.parallax > use:nth-child(3) {
		animation-delay: -4s;
		animation-duration: 13s;
	}
	.parallax > use:nth-child(4) {
		animation-delay: -5s;
		animation-duration: 20s;
	}

	@media (max-width: 900px) {
		.speaker-section {
			padding: 5rem 1.5rem 7rem;
		}

		.title {
			width: 100%;
			margin-bottom: 2rem;
			grid-template-columns: max-content 1fr;
			row-gap: 0.5rem;
			column-gap: 0.9375rem;
			align-items: center;
		}

		.line {
			width: 100%;
			margin: 0;
			align-self: center;
		}

		.title h2:nth-of-type(2) {
			grid-column: 1 / -1;
			margin-left: 2rem;
		}

		.content-wrapper {
			flex-direction: column;
			gap: 2.5rem;
			max-width: 100%;
		}

		.speaker-list {
			width: 100%;
		}

		.speaker-item {
			font-size: 1.25rem;
			flex-direction: column;
			align-items: flex-start;
		}

		.speakerdesc {
			order: 0;
			width: auto;
			flex-shrink: 1;
			font-size: 1rem;
			text-align: left;
			padding-right: 0;
			padding-left: 0;
			margin-top: 0.25rem;
			color: var(--metal-muted);
		}

		.speaker-image {
			width: calc(100% + 3rem);
			margin-left: -1.5rem;
			overflow: hidden;
		}

		.desktop-img {
			display: none;
		}

		.marquee-container {
			display: block;
			width: 100%;
		}

		.marquee-track {
			display: flex;
			width: max-content;
			gap: 0.625rem;
			animation: scroll 20s linear infinite;
		}

		.marquee-item {
			height: 15.625rem;
			width: auto;
			border-radius: 0.75rem;
			box-shadow: var(--metal-card-shadow);
			flex-shrink: 0;
		}

		.cta-btn {
			width: auto;
			text-align: center;
			padding: 0.625rem 2rem;
			font-size: 1.2rem;
		}

		.bg-optimized {
			height: 70%;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.parallax > use {
			animation: none;
		}

		.marquee-track {
			animation: none;
		}

		.speaker-item {
			transition: none;
		}

		.desktop-img {
			transition: none;
		}

		.cta-btn {
			transition: none;
		}
	}
</style>

<script>
	import { gsap } from "gsap";

	const initSpeaker = () => {
		const container = document.querySelector(".speaker-section") as HTMLElement | null;
		if (!container) return () => {};
		if (container.dataset.speakerInit === "true") return () => {};
		container.dataset.speakerInit = "true";

		const items = document.querySelectorAll<HTMLElement>(".speaker-item");
		const imgelement = document.getElementById("speaker-img") as HTMLImageElement | null;
		const speakerlist = document.querySelector<HTMLElement>(".speaker-list");
		const contentwrapper = document.querySelector<HTMLElement>(".content-wrapper");
		const desktopimg = document.querySelector<HTMLElement>(".desktop-img");
		let currentindex = 0;

		if (!speakerlist || items.length === 0) {
			container.dataset.speakerInit = "false";
			return () => {};
		}

		const updateview = (index: number) => {
			items.forEach(item => {
				item.classList.remove("active");
			});

			const targetitem = items[index];
			targetitem.classList.add("active");

			const newimgsrc = targetitem.getAttribute("data-img");
			const newalt = targetitem.getAttribute("data-alt");
			if (imgelement && newimgsrc) {
				imgelement.src = newimgsrc;
				imgelement.alt = newalt ?? "";
			}

			currentindex = index;
		};

		let timer: number | null = null;

		const startautoplay = () => {
			if (timer) return;
			timer = window.setInterval(() => {
				const nextindex = (currentindex + 1) % items.length;
				updateview(nextindex);
			}, 2000);
		};

		const stopautoplay = () => {
			if (timer) window.clearInterval(timer);
			timer = null;
		};

		const itemEnterHandlers = new Map<HTMLElement, () => void>();

		items.forEach((item, index) => {
			const enterHandler = () => {
				updateview(index);
				stopautoplay();
			};
			itemEnterHandlers.set(item, enterHandler);
			item.addEventListener("mouseenter", enterHandler);
		});

		const wrapperMoveHandler = (e: MouseEvent) => {
			if (!desktopimg || !contentwrapper) return;
			const { clientX, clientY } = e;
			const { left, width, top, height } = contentwrapper.getBoundingClientRect();
			const x = clientX - left;
			const y = clientY - top;
			const translatex = gsap.utils.mapRange(0, width, -60, 60, x);
			const translatey = gsap.utils.mapRange(0, height, -60, 60, y);

			gsap.to(desktopimg, {
				x: translatex,
				y: translatey,
				duration: 0.15,
				ease: "power2.out"
			});
		};

		contentwrapper?.addEventListener("mousemove", wrapperMoveHandler);

		const listLeaveHandler = () => {
			startautoplay();
			if (!desktopimg) return;
			gsap.to(desktopimg, {
				x: 0,
				y: 0,
				duration: 0.4,
				ease: "power2.out"
			});
		};

		contentwrapper?.addEventListener("mouseleave", listLeaveHandler);
		speakerlist.addEventListener("mouseleave", listLeaveHandler);

		startautoplay();

		return () => {
			stopautoplay();
			itemEnterHandlers.forEach((handler, item) => {
				item.removeEventListener("mouseenter", handler);
			});
			contentwrapper?.removeEventListener("mousemove", wrapperMoveHandler);
			contentwrapper?.removeEventListener("mouseleave", listLeaveHandler);
			speakerlist.removeEventListener("mouseleave", listLeaveHandler);
			container.dataset.speakerInit = "false";
		};
	};

	let cleanup: (() => void) | null = null;
	const mount = () => {
		cleanup?.();
		cleanup = initSpeaker();
	};

	const pageLoadHandler = () => {
		mount();
	};

	const beforeSwapHandler = () => {
		cleanup?.();
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", mount, { once: true });
	} else {
		mount();
	}

	document.addEventListener("astro:page-load", pageLoadHandler);
	document.addEventListener("astro:before-swap", beforeSwapHandler);
</script>
