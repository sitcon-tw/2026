---
import { ExternalLink } from "@lucide/astro";
import { useTranslations, type Lang } from "@/utils/i18n";

interface Props {
	lang?: Lang;
}

const lang = Astro.props.lang ?? "zh";
const t = useTranslations(lang).joinUs;
---

<section id="sponsors">
	<div class="title">
		<h2 class="text-reveal-title">{t.title1}</h2>
		<h2 class="text-reveal-title">{t.title2}</h2>
	</div>
	<div class="content-container">
		<div class="content-text">
			<p class="text-reveal-paragraph" set:html={t.description} />
		</div>
		<div class="content-list">
			{t.stats.map((stat: string) => <p class="text-reveal-paragraph">{stat}</p>)}
		</div>
		<div class="content-btn">
			<a href="https://sitcon.org/2026/cfs/">
				<div class="hover-bg"></div>
				<span>
					<div>{t.buttons.sponsorRequest}</div>
					<ExternalLink class="arrow-icon" />
				</span>
			</a>

			<a href="https://sitcon.org/donate/">
				<div class="hover-bg"></div>
				<span>
					{t.buttons.personalSponsor}
					<ExternalLink class="arrow-icon" />
				</span>
			</a>
		</div>
	</div>
</section>

<style>
	section {
		background: radial-gradient(circle at 18% 20%, rgba(216, 212, 199, 0.12), transparent 28rem), linear-gradient(180deg, rgba(244, 239, 229, 0.96), rgba(229, 218, 195, 0.94));
		color: var(--coffee);
	}
	.title {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: clamp(1rem, 3vw, 2rem);
		max-width: var(--max-width);
		margin: 0 auto;
		padding-top: 5rem;
		width: 90%;
	}

	.title::before {
		content: "";
		order: 2;
		flex: 1 1 auto;
		height: 1px;
		min-width: 8rem;
		background: linear-gradient(90deg, rgba(45, 33, 17, 0.08), rgba(45, 33, 17, 0.52), rgba(45, 33, 17, 0.08));
		box-shadow: 0 0 1.25rem rgba(141, 99, 48, 0.18);
		transform: translateY(0.18em);
	}

	h2 {
		flex: 0 0 auto;
		color: rgba(45, 33, 17, 0.56);
	}

	h2:first-of-type {
		order: 1;
	}

	h2:nth-of-type(2) {
		order: 3;
		color: var(--coffee);
	}

	.content-container {
		width: 75rem;
		display: flex;
		flex-direction: column;
		margin: 0 auto;
	}

	.content-text {
		text-align: center;
		color: var(--coffee);
		font-size: 1.2rem;
		font-weight: 500;
		margin: 5rem 10rem auto;
	}

	.content-list {
		color: var(--coffee);
		font-weight: bold;
		margin: 5rem 12rem;
	}
	.content-btn {
		display: flex;
		justify-content: center;
		gap: 2rem;
		margin-bottom: 5rem;
	}
	.content-btn a {
		border-radius: 62.5rem;
		padding: 1rem 2rem;
		font-size: 1.5rem;
		display: flex;
		justify-content: center;
		align-items: center;
		cursor: pointer;
		text-decoration: none;
		font-weight: bold;
		color: var(--metal-ink);
		background: linear-gradient(145deg, var(--metal-cream), var(--metal-silver));
		border: 0.0625rem solid rgba(45, 33, 17, 0.28);
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
		overflow: hidden;
		position: relative;
		z-index: 1;
		box-sizing: border-box;
	}

	.hover-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background:
			linear-gradient(124deg, rgba(216, 212, 199, 0.2) -3.36%, rgba(216, 212, 199, 0.72) 48%, rgba(141, 99, 48, 0.28) 100%),
			radial-gradient(390.63% 225.3% at 8.72% -121.17%, #fff 0%, rgba(255, 255, 255, 0) 100%);
		transform: translateX(-100%);
		z-index: -1;
	}

	.content-btn a span {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		min-width: 0;
		max-width: 100%;
	}

	.content-btn a span > div {
		min-width: 0;
	}

	.content-btn a:hover {
		transform: translateY(-0.1875rem);
		box-shadow: 0 0.75rem 1.5rem rgba(45, 33, 17, 0.16);
		border-color: rgba(45, 33, 17, 0.44);
	}

	.content-btn a svg path {
		transition: stroke 0.3s ease;
	}

	@media screen and (max-width: 1250px) {
		.content-container {
			width: 100%;
			padding: 0 1.5rem;
			box-sizing: border-box;
		}

		.content-text {
			margin: 3rem auto;
			max-width: 90%;
		}

		.content-list {
			width: fit-content;
		}
	}

	@media screen and (max-width: 50rem) {
		.title {
			flex-direction: column;
			align-items: stretch;
			padding: 3rem 2rem 0;
			gap: 0.65rem;
			margin: 0 auto;
		}

		.title::before {
			width: min(100%, 18rem);
			min-width: 0;
			flex: 0 0 auto;
			margin: 0.15rem 0 0.1rem auto;
			transform: none;
		}

		.title h2:nth-of-type(2) {
			display: flex;
			justify-content: flex-end;
		}

		.content-text {
			margin: 2rem auto;
			font-size: 1rem;
			text-align: left;
			line-height: 1.6;
		}

		.content-text br {
			display: none;
		}

		.content-list {
			font-size: 1rem;
			margin: 1rem auto 3rem auto;
		}

		.content-btn {
			flex-direction: row;
			gap: 0.65rem;
			align-items: center;
			width: 100%;
			padding: 0 clamp(0.75rem, 4vw, 1rem);
			box-sizing: border-box;
		}

		.content-btn a {
			width: auto;
			flex: 1;
			max-width: none;
			min-width: 0;
			height: auto;
			min-height: 3.85rem;
			padding: 0.68rem 0.8rem 0.68rem 0.95rem;
			font-size: clamp(0.78rem, 3.7vw, 0.95rem);
			line-height: 1.05;
			justify-content: stretch;
			text-align: left;
		}

		.content-btn a span {
			display: grid;
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: center;
			gap: 0.45rem;
			width: 100%;
			white-space: normal;
			overflow-wrap: break-word;
		}

		.content-btn a span > div {
			line-height: inherit;
		}

		.content-btn a svg {
			width: 1.05rem;
			height: 1.05rem;
			align-self: start;
			margin-top: 0.02rem;
			flex: 0 0 auto;
		}
	}

	@media screen and (max-width: 23rem) {
		.content-btn {
			flex-direction: column;
			align-items: stretch;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.content-btn a {
			transition: none;
		}

		.content-btn a svg path {
			transition: none;
		}

		.hover-bg {
			transform: none;
		}
	}
</style>

<script>
	import { gsap } from "gsap";

	const buttons = document.querySelectorAll(".content-btn a");

	buttons.forEach(btn => {
		const content = btn.querySelector("span");
		const hoverBg = btn.querySelector(".hover-bg");

		btn.addEventListener("mouseenter", () => {
			gsap.killTweensOf([content, hoverBg]);

			// Text rolling effect
			gsap.to(content, {
				x: 20,
				opacity: 0,
				duration: 0.3,
				ease: "power2.in",
				onComplete: () => {
					gsap.set(content, { x: -20 });
					gsap.to(content, { x: 0, opacity: 1, duration: 0.3, ease: "power2.out" });
				}
			});

			// Background rolling effect
			gsap.fromTo(hoverBg, { x: "-100%" }, { x: "0%", duration: 0.5, ease: "power2.out" });
		});

		btn.addEventListener("mouseleave", () => {
			gsap.killTweensOf([content, hoverBg]);

			gsap.to(content, { x: 0, opacity: 1, duration: 0.3, ease: "power2.out" });

			gsap.to(hoverBg, {
				x: "100%",
				duration: 0.5,
				ease: "power2.in",
				onComplete: () => {
					gsap.set(hoverBg, { x: "-100%" });
				}
			});
		});
	});
</script>
