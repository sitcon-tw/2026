---
import { X } from "@lucide/astro";
import { useTranslations, type Lang } from "@/utils/i18n";

interface Props {
	lang?: Lang;
}

const lang = Astro.props.lang ?? "zh";
const t = useTranslations(lang).dialogue;
---

<div class="dialogue-section">
	<h2 set:html={t.headline} />
	<p class="text-reveal-paragraph">{t.paragraph1}</p>
	<p class="text-reveal-paragraph">{t.paragraph2}</p>
	<button id="dialog-trigger">{t.dialogTrigger}</button>
	<p class="text-reveal-paragraph intro">{t.paragraph3}</p>
</div>

<div class="dialog-wrapper">
	<div class="dialog-container">
		<div class="dialog">
			<button class="dialog-close"><X /></button>
			<h2 class="dialog-title" set:html={t.headline} />
			<p set:html={t.dialog.fullParagraph} />
			<h3 class="dialog-subtitle">{t.dialog.title}</h3>
			<div class="featured-list">
				{
					t.dialog.featured.map(item => (
						<a class="featured-item" href={`/2026/${lang == "en" ? "en/" : ""}agenda/${item.id}/`} target="_blank" rel="noopener noreferrer">
							{item.name}
							<span>{item.type}</span>
						</a>
					))
				}
			</div>
		</div>
	</div>
</div>

<script>
	import gsap from "gsap";

	const dialogTrigger = document.getElementById("dialog-trigger") as HTMLButtonElement;
	const dialogWrapper = document.querySelector(".dialog-wrapper") as HTMLDivElement;
	const dialogClose = document.querySelector(".dialog-close") as HTMLButtonElement;
	const dialogContainer = document.querySelector(".dialog-container") as HTMLDivElement;
	const dialog = document.querySelector(".dialog") as HTMLDivElement;

	gsap.set(dialogWrapper, { autoAlpha: 0 });
	gsap.set(dialog, { y: -50, autoAlpha: 0 });

	dialogTrigger.addEventListener("click", () => {
		document.body.style.overflow = "hidden";
		gsap.to(dialogWrapper, { autoAlpha: 1, y: 0, duration: 0.2, ease: "power2.out" });
		gsap.to(dialog, { autoAlpha: 1, y: 0, duration: 0.5, ease: "power2.out", delay: 0.1 });
	});

	function closeDialog() {
		gsap.to(dialog, { autoAlpha: 0, y: -50, duration: 0.5, ease: "power2.out" });
		gsap.to(dialogWrapper, { autoAlpha: 0, duration: 0.2, ease: "power2.out", delay: 0.1 });
		document.body.style.overflow = "";
	}

	dialogClose.addEventListener("click", closeDialog);

	dialogContainer.addEventListener("click", e => {
		if (e.target == dialogContainer) {
			closeDialog();
		}
	});

	document.addEventListener("keydown", e => {
		if (e.key === "Escape" && dialog.style.opacity != "0") {
			closeDialog();
		}
	});

	dialogContainer.addEventListener("wheel", e => {
		e.stopPropagation();
		dialogContainer.scrollTop += e.deltaY;
	});
</script>

<style>
	.dialogue-section {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 8rem 2rem;
	}

	h2 {
		font-weight: 700;
		font-size: min(2.5rem, 6vw);
		line-height: 1.6;
		text-align: center;
		margin-bottom: 6rem;
	}

	:global(.lang-en) .dialogue-section h2 {
		font-size: min(2.2rem, 5vw);
	}

	p {
		font-size: 1.125rem;
		line-height: 2;
		margin-bottom: 2rem;
		text-align: justify;
		max-width: 45rem;
	}

	.intro {
		margin-left: auto;
		margin-top: 5rem;
	}

	#dialog-trigger {
		display: block;
		margin: 3rem auto;
		padding: 0.75rem 1.5rem;
		font-size: 1rem;
		background-color: rgba(255, 255, 255, 0.2);
		color: #fff;
		border: 0.1rem solid rgba(232, 187, 95, 0.5);
		border-radius: 10rem;
		box-shadow: 0 0.2rem 0.5rem rgba(0, 0, 0, 0.1);
		transition: all 0.3s ease;
		cursor: pointer;
	}

	#dialog-trigger:hover {
		box-shadow: 0 0.2rem 1rem rgba(0, 0, 0, 0.2);
		transform: translateY(-0.2rem);
		border: 0.1rem solid rgba(232, 187, 95, 1);
		background-color: rgba(255, 255, 255, 0.4);
	}

	.dialog-wrapper {
		inset: 0;
		position: fixed;
		background-color: rgba(0, 0, 0, 0.5);
		z-index: 1000;
	}

	.dialog-container {
		overflow-y: scroll;
		pointer-events: all;
		height: 100%;
		padding: 2rem 1rem;
	}
	.dialog {
		position: relative;
		padding: 4rem 4rem;
		margin: auto;
		background: #3c2d0e;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		border-radius: 1rem;
		max-width: 50rem;
		width: 100%;
		line-height: 1.6;
	}

	.dialog-title {
		color: #e8bb5f;
		margin-bottom: 1rem;
		font-size: 2rem;
	}

	.dialog-subtitle {
		color: #e8bb5f;
		margin-top: 2rem;
		font-size: 1.5rem;
		text-align: center;
	}

	.featured-list {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		justify-content: center;
		margin-top: 2rem;
	}

	.featured-item {
		padding: 1rem;
		display: block;
		margin: 0 auto;
		font-size: 1rem;
		background-color: rgba(255, 255, 255, 0.2);
		color: #fff;
		border: 0.1rem solid rgba(232, 187, 95, 0.5);
		border-radius: 1em;
		box-shadow: 0 0.2rem 0.5rem rgba(0, 0, 0, 0.1);
		transition: all 0.3s ease;
		line-height: 1.3rem;
		span {
			opacity: 0.5;
			margin-left: 0.5rem;
			line-height: 1rem;
			white-space: nowrap;
		}
		span::before {
			content: "-";
			margin-right: 0.2rem;
		}
	}

	.featured-item:hover {
		box-shadow: 0 0.2rem 1rem rgba(0, 0, 0, 0.2);
		transform: translateY(-0.2rem);
		border: 0.1rem solid rgba(232, 187, 95, 1);
		background-color: rgba(255, 255, 255, 0.4);
	}

	@media (max-width: 50rem) {
		.dialog {
			padding: 1.5rem;
		}
		.featured-item {
			width: 100%;
			display: flex;
			flex-direction: column-reverse;
			span {
				margin-bottom: 0.5rem;
				margin-left: 0;
			}
			span::before {
				content: "";
				margin: 0;
			}
		}
	}

	.dialog-close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		background: none;
		border: none;
		color: #fff;
		cursor: pointer;
		padding: 0.5rem;
		font-size: 1rem;
		border-radius: 50%;
		transition: background-color 0.3s ease;
		background-color: rgba(255, 255, 255, 0.1);
		width: 2.5rem;
		height: 2.5rem;
	}

	.dialog-close:hover {
		background-color: rgba(255, 255, 255, 0.2);
	}
</style>
