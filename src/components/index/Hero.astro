---
import Landing from "./Hero/Landing.astro";
import Dialogue from "./Hero/Dialogue.astro";
import PhotoWall from "./Hero/PhotoWall.astro";
import type { Lang } from "@/utils/i18n";

interface Props {
	lang?: Lang;
}

const lang = Astro.props.lang ?? "zh";
---

<section class="hero-container">
	<div class="bg-fixed">
		<canvas id="bg-canvas"></canvas>
	</div>
	<Landing lang={lang} />
	<Dialogue lang={lang} />
	<PhotoWall lang={lang} />
</section>

<style>
	.hero-container {
		position: relative;
		width: 100%;
	}

	.bg-fixed {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100dvh;
		overflow: hidden;
		background: radial-gradient(circle at 56% 36%, rgba(246, 216, 142, 0.38) 0%, rgba(184, 137, 45, 0.22) 34%, transparent 62%), linear-gradient(135deg, #6b4a18 0%, #aa7d2e 48%, #493514 100%);
		z-index: -1;
		animation: fadeIn 2s ease-out forwards;
	}

	.bg-fixed::before,
	.bg-fixed::after {
		content: "";
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.bg-fixed::before {
		z-index: 0;
		background: repeating-linear-gradient(108deg, rgba(255, 244, 207, 0.055) 0 1px, transparent 1px 9px), repeating-linear-gradient(18deg, rgba(36, 24, 8, 0.04) 0 1px, transparent 1px 13px);
		mix-blend-mode: soft-light;
		opacity: 0.62;
	}

	.bg-fixed::after {
		z-index: 2;
		background: radial-gradient(ellipse at 52% 42%, transparent 0%, transparent 48%, rgba(28, 18, 4, 0.34) 100%);
	}

	@media (prefers-reduced-motion: reduce) {
		.bg-fixed {
			animation: none;
			opacity: 1;
		}
	}

	@keyframes fadeIn {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	#bg-canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
	}

	.hero-container :global(.dialogue-section),
	.hero-container :global(.photo-wall) {
		pointer-events: none;
	}

	.hero-container :global(a),
	.hero-container :global(button),
	.hero-container :global(.cta-container) {
		pointer-events: auto;
	}
</style>

<script>
	import * as THREE from "three";
	// @ts-ignore - SVGLoader types may not be available
	import { SVGLoader, type SVGResult } from "three/examples/jsm/loaders/SVGLoader";
	import { RoomEnvironment } from "three/examples/jsm/environments/RoomEnvironment.js";
	import { RoundedBoxGeometry } from "three/examples/jsm/geometries/RoundedBoxGeometry.js";
	import { Line2 } from "three/examples/jsm/lines/Line2.js";
	import { LineGeometry } from "three/examples/jsm/lines/LineGeometry.js";
	import { LineMaterial } from "three/examples/jsm/lines/LineMaterial.js";
	import { createSeededRandom, createVortexConfig, getDepthOpacity, getVortexPosition, goldenAngle, type HeroObjectRole } from "./Hero/vortex";
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	const prefersReducedMotion = () => window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	const initHeroBackground = () => {
		const canvas = document.getElementById("bg-canvas") as HTMLCanvasElement | null;
		const heroContainer = document.querySelector(".hero-container") as HTMLElement | null;
		if (!canvas || !heroContainer) return () => {};
		if (heroContainer.dataset.heroInit === "true") return () => {};
		heroContainer.dataset.heroInit = "true";

		const narrowViewport = window.innerWidth < 700;
		const reduceMotion = prefersReducedMotion();
		const random = createSeededRandom();

		const scene = new THREE.Scene();
		const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
		camera.position.set(0, 0, 0); // Camera at center

		const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
		renderer.setSize(window.innerWidth, window.innerHeight);
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
		renderer.outputColorSpace = THREE.SRGBColorSpace;
		renderer.toneMapping = THREE.ACESFilmicToneMapping;
		renderer.toneMappingExposure = 1.08;

		const pmremGenerator = new THREE.PMREMGenerator(renderer);
		const environmentScene = new RoomEnvironment();
		const environmentRenderTarget = pmremGenerator.fromScene(environmentScene, 0.04);
		scene.environment = environmentRenderTarget.texture;

		// Reusable vector for lerp operations to avoid GC pressure
		const tempVec3 = new THREE.Vector3();
		const ribbonPoint = new THREE.Vector3();
		const meteorPos = new THREE.Vector3();
		const meteorNextPos = new THREE.Vector3();

		// Lighting
		const ambientLight = new THREE.HemisphereLight(0xfff2d2, 0x1b1406, 1.0);
		scene.add(ambientLight);

		const keyLight = new THREE.DirectionalLight(0xffe3a4, 3.2);
		keyLight.position.set(-8, 9, -8);
		scene.add(keyLight);

		const rimLight = new THREE.DirectionalLight(0xd8e5ff, 2.4);
		rimLight.position.set(10, -4, -14);
		scene.add(rimLight);

		const fillLight = new THREE.PointLight(0xfff6df, 32, 150, 2);
		fillLight.position.set(0, 14, -22);
		scene.add(fillLight);

		const vortexConfig = createVortexConfig(narrowViewport);

		interface HeroObject {
			mesh: THREE.Object3D;
			pathOffset: number;
			speed: number;
			isDragging: boolean;
			targetPos: THREE.Vector3;
			rotationSpeed: THREE.Euler;
			baseScale: number;
			vortexLevel: number;
			radiusBias: number;
			verticalOffset: number;
		}

		// Meteors (Improved trails with Shaders)
		const meteorsGroup = new THREE.Group();
		const meteorCount = narrowViewport ? 10 : 18;
		const meteors: { mesh: THREE.Mesh; speed: number; progress: number; offset: number; radiusBias: number; verticalOffset: number }[] = [];

		const meteorLength = narrowViewport ? 14 : 20;
		const meteorGeometry = new THREE.CylinderGeometry(0.006, 0.085, meteorLength, 8); // v=1(Top) is thin tail, v=0(Bottom) is thick head
		meteorGeometry.translate(0, meteorLength / 2, 0); // Move Bottom(Head) to origin
		meteorGeometry.rotateX(-Math.PI / 2); // Rotate so head (v=0) points forward (+Z)

		const meteorShaderMaterial = new THREE.ShaderMaterial({
			uniforms: {
				color: { value: new THREE.Color(0xf4e7c8) },
				opacity: { value: 0.24 }
			},
			vertexShader: `
				varying vec2 vUv;
				void main() {
					vUv = uv;
					gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				varying vec2 vUv;
				uniform vec3 color;
				uniform float opacity;
				void main() {
					// vUv.y is from 0 (head) to 1 (tail)
					// Smooth head, long fading tail
					float alpha = smoothstep(0.0, 0.05, vUv.y) * pow(1.0 - vUv.y, 3.0);
					// Add a core brightness
					gl_FragColor = vec4(color, alpha * opacity);
				}
			`,
			transparent: true,
			blending: THREE.AdditiveBlending,
			depthWrite: false
		});

		for (let i = 0; i < meteorCount; i++) {
			const mesh = new THREE.Mesh(meteorGeometry, meteorShaderMaterial.clone());
			meteorsGroup.add(mesh);
			meteors.push({
				mesh,
				speed: (narrowViewport ? 0.00042 : 0.00034) + random() * 0.00018,
				progress: (i + 0.5) / meteorCount + (random() - 0.5) * 0.012,
				offset: i * goldenAngle + random() * 0.22,
				radiusBias: 0.92 + random() * 0.26,
				verticalOffset: (random() - 0.5) * (narrowViewport ? 7 : 9)
			});
		}
		scene.add(meteorsGroup);

		const ribbonPointCount = 120;
		const vortexRibbons: {
			line: Line2;
			geometry: LineGeometry;
			material: LineMaterial;
			offset: number;
			radiusBias: number;
			verticalOffset: number;
			positions: Float32Array;
			opacity: number;
		}[] = [];

		const createVortexRibbon = (offset: number, radiusBias: number, verticalOffset: number, opacity: number) => {
			const geometry = new LineGeometry();
			const positions = new Float32Array(ribbonPointCount * 3);
			geometry.setPositions(positions);
			const material = new LineMaterial({
				color: 0xffe8ad,
				linewidth: narrowViewport ? 2.2 : 2.8,
				transparent: true,
				opacity,
				blending: THREE.AdditiveBlending,
				depthWrite: false,
				resolution: new THREE.Vector2(window.innerWidth, window.innerHeight)
			});
			const line = new Line2(geometry, material);
			line.computeLineDistances();
			scene.add(line);
			vortexRibbons.push({ line, geometry, material, offset, radiusBias, verticalOffset, positions, opacity });
		};

		for (let i = 0; i < (narrowViewport ? 2 : 3); i++) {
			createVortexRibbon(i * goldenAngle + random() * 0.2, 0.8 + i * 0.15, (i - 1) * (narrowViewport ? 3.5 : 4.5), narrowViewport ? 0.32 : 0.42);
		}

		// Orbiting Decorative Objects
		const heroObjects: HeroObject[] = [];
		const decorInstanceCount = narrowViewport ? 1 : 2;
		let objectSlotCursor = 0;
		const screenVec3 = new THREE.Vector3();

		const levelSequence = narrowViewport ? [0.17, 0.29, 0.41, 0.53, 0.65, 0.77, 0.87] : [0.12, 0.21, 0.3, 0.39, 0.49, 0.59, 0.69, 0.79, 0.88];

		const getObjectPlacement = (role: HeroObjectRole) => {
			const slot = objectSlotCursor++;
			const sequenceLevel = levelSequence[slot % levelSequence.length] ?? 0.5;
			const level = THREE.MathUtils.clamp(sequenceLevel + (random() - 0.5) * (narrowViewport ? 0.035 : 0.045), 0.08, 0.94);
			const roleOffset = role === "orb" ? 0 : role === "ring" ? 0.74 : role === "facet" ? 1.28 : 1.78;
			const radiusBiasBase = role === "orb" ? 0.82 : role === "ring" ? 1.03 : role === "facet" ? 0.9 : 1.08;
			return {
				level,
				thetaOffset: (level * Math.PI * -1.15 + slot * goldenAngle + roleOffset + random() * 0.2) % (Math.PI * 2),
				radiusBias: radiusBiasBase + random() * (role === "orb" ? 0.28 : 0.22),
				verticalOffset: (random() - 0.5) * (narrowViewport ? 5.2 : 7.5)
			};
		};

		const getContentFade = (worldPosition: THREE.Vector3) => {
			screenVec3.copy(worldPosition).project(camera);
			const screenX = (screenVec3.x + 1) / 2;
			const screenY = (1 - screenVec3.y) / 2;
			if (screenVec3.z < -1 || screenVec3.z > 1) return 1;

			if (window.innerWidth < 700) {
				const overTitle = screenX < 0.64 && screenY > 0.12 && screenY < 0.5;
				const overCta = screenX < 0.9 && screenY > 0.68 && screenY < 0.86;
				const overLocation = screenY > 0.82;
				const overHeader = screenY < 0.12;
				return overTitle || overCta || overLocation || overHeader ? 0.08 : 1;
			}

			const overTitle = screenX < 0.34 && screenY > 0.12 && screenY < 0.46;
			const overLocation = screenX > 0.52 && screenY > 0.82;
			const overCta = screenX < 0.24 && screenY > 0.72 && screenY < 0.88;
			const overHeader = screenY < 0.12 && screenX > 0.36;
			return overTitle || overLocation || overCta || overHeader ? 0.08 : 1;
		};

		const createOrbitingObjects = (
			geometry: THREE.BufferGeometry,
			material: THREE.Material,
			count: number,
			scaleRange: [number, number],
			speedRange: [number, number],
			role: HeroObjectRole = "decor"
		) => {
			for (let i = 0; i < count; i++) {
				const mesh = new THREE.Mesh(geometry, material.clone());
				const placement = getObjectPlacement(role);
				const middleWeight = Math.sin(placement.level * Math.PI);
				const roleScaleBoost = role === "orb" ? 1 + middleWeight * 0.08 : role === "decor" ? 0.9 : 1;
				const scale = (scaleRange[0] + random() * (scaleRange[1] - scaleRange[0])) * roleScaleBoost;
				mesh.scale.setScalar(scale);
				getVortexPosition(vortexConfig, narrowViewport, placement.level, placement.thetaOffset, placement.radiusBias, placement.verticalOffset, 0, mesh.position);

				scene.add(mesh);
				heroObjects.push({
					mesh,
					pathOffset: placement.thetaOffset,
					speed: speedRange[0] + random() * (speedRange[1] - speedRange[0]),
					isDragging: false,
					targetPos: new THREE.Vector3(),
					rotationSpeed: new THREE.Euler((random() - 0.5) * 0.005, (random() - 0.5) * 0.005, (random() - 0.5) * 0.005),
					baseScale: scale,
					vortexLevel: placement.level,
					radiusBias: placement.radiusBias,
					verticalOffset: placement.verticalOffset
				});

				if (reduceMotion) {
					renderer.render(scene, camera);
				}
			}
		};

		const raycaster = new THREE.Raycaster();
		const mouse = new THREE.Vector2();
		const plane = new THREE.Plane();
		const intersection = new THREE.Vector3();
		const offset = new THREE.Vector3();
		let draggedObj: HeroObject | null = null;

		const createMetalMaterial = (color: THREE.ColorRepresentation, roughness = 0.32, envMapIntensity = 1.75) => {
			return new THREE.MeshPhysicalMaterial({
				color: color,
				metalness: 1.0,
				roughness,
				reflectivity: 0.65,
				clearcoat: 0.22,
				clearcoatRoughness: 0.34,
				envMapIntensity
			});
		};

		const svgLoader = new SVGLoader();
		// textureLoader removed - was declared but never used

		// Add Volumetric Primitives (Cubes & Spheres & Toruses)
		const cubeGeom = new RoundedBoxGeometry(2, 2, 2, 5, 0.1);
		const sphereGeom = new THREE.IcosahedronGeometry(1.2, 4); // Increased detail from 1 to 4 for smoothness
		const torusGeom = new THREE.TorusGeometry(1, 0.4, 32, 48); // Also increased torus segments for smoothness

		const goldMat = createMetalMaterial(0xd1a348, 0.28, 2.0);
		const silverMat = createMetalMaterial(0xc9c8bb, 0.34, 1.8);
		const copperMat = createMetalMaterial(0xa96330, 0.36, 1.6);

		createOrbitingObjects(sphereGeom, silverMat, narrowViewport ? 10 : 16, narrowViewport ? [0.75, 1.35] : [1.05, 2.05], [0.0003, 0.00052], "orb");
		createOrbitingObjects(cubeGeom, goldMat, narrowViewport ? 3 : 5, narrowViewport ? [0.48, 1.0] : [0.6, 1.35], [0.00026, 0.00048], "facet");
		createOrbitingObjects(torusGeom, copperMat, narrowViewport ? 2 : 4, narrowViewport ? [0.45, 1.05] : [0.58, 1.45], [0.00026, 0.00046], "ring");

		// round-metal.svg
		svgLoader.load("/2026/img/Hero/round-metal.svg", (data: SVGResult) => {
			const shapes: THREE.Shape[] = [];
			data.paths.forEach((path: any) => shapes.push(...SVGLoader.createShapes(path)));
			const geometry = new THREE.ExtrudeGeometry(shapes, { depth: 15, bevelEnabled: true }); // Increased depth
			geometry.center();
			geometry.rotateX(Math.PI); // Correct SVG flip

			const baseColor = data.paths[0]?.color || 0xdaa520;
			const material = createMetalMaterial(baseColor, 0.3, 1.9);

			// Orbiting Background (now draggable)
			createOrbitingObjects(geometry, material, decorInstanceCount, narrowViewport ? [0.028, 0.08] : [0.026, 0.095], [0.00024, 0.00042], "decor");
		});

		// stone-metal.svg
		svgLoader.load("/2026/img/Hero/stone-metal.svg", (data: SVGResult) => {
			const shapes: THREE.Shape[] = [];
			data.paths.forEach((path: any) => shapes.push(...SVGLoader.createShapes(path)));
			const geometry = new THREE.ExtrudeGeometry(shapes, { depth: 18, bevelEnabled: true }); // Increased depth
			geometry.center();
			geometry.rotateX(Math.PI);

			const baseColor = data.paths[0]?.color || 0xdfdfdf;
			const material = createMetalMaterial(baseColor, 0.34, 1.75);

			// Orbiting Background (now draggable)
			createOrbitingObjects(geometry, material, decorInstanceCount, narrowViewport ? [0.032, 0.095] : [0.03, 0.12], [0.00024, 0.00042], "decor");
		});

		// star-metal.svg
		svgLoader.load("/2026/img/Hero/star-metal.svg", (data: SVGResult) => {
			const shapes: THREE.Shape[] = [];
			data.paths.forEach((path: any) => shapes.push(...SVGLoader.createShapes(path)));
			const geometry = new THREE.ExtrudeGeometry(shapes, { depth: 12, bevelEnabled: true }); // Increased depth
			geometry.center();
			geometry.rotateX(Math.PI);

			const baseColor = data.paths[0]?.color || 0xffffff;
			const material = createMetalMaterial(baseColor, 0.32, 1.8);

			// Orbiting Background (now draggable)
			createOrbitingObjects(geometry, material, decorInstanceCount, narrowViewport ? [0.038, 0.12] : [0.036, 0.15], [0.00024, 0.00042], "decor");
		});

		// Drag Events
		const onPointerDown = (e: PointerEvent) => {
			mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
			mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
			raycaster.setFromCamera(mouse, camera);
			const intersects = raycaster.intersectObjects(
				heroObjects.map(o => o.mesh),
				true
			);
			if (intersects.length > 0) {
				let root = intersects[0].object;
				while (root.parent && root.parent !== scene) root = root.parent;
				draggedObj = heroObjects.find(o => o.mesh === root) || null;
				if (draggedObj) {
					draggedObj.isDragging = true;
					canvas.style.cursor = "grabbing";
					plane.setFromNormalAndCoplanarPoint(camera.getWorldDirection(new THREE.Vector3()).negate(), intersects[0].point);
					if (raycaster.ray.intersectPlane(plane, intersection)) {
						offset.copy(intersection).sub(root.position);
					}
				}
			}
		};

		const onPointerMove = (e: PointerEvent) => {
			mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
			mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;

			if (draggedObj && draggedObj.isDragging) {
				raycaster.setFromCamera(mouse, camera);
				if (raycaster.ray.intersectPlane(plane, intersection)) {
					draggedObj.mesh.position.copy(intersection.sub(offset));
				}
			} else {
				// Hover check for cursor change
				raycaster.setFromCamera(mouse, camera);
				const intersects = raycaster.intersectObjects(
					heroObjects.filter(o => o.mesh.visible).map(o => o.mesh),
					true
				);
				canvas.style.cursor = intersects.length > 0 ? "grab" : "auto";
			}
		};

		const onPointerUp = () => {
			if (draggedObj) {
				draggedObj.isDragging = false;
				draggedObj = null;
				canvas.style.cursor = "auto";
			}
		};

		window.addEventListener("pointerdown", onPointerDown);
		window.addEventListener("pointermove", onPointerMove);
		window.addEventListener("pointerup", onPointerUp);

		let scrollProgress = 0;
		let idleTime = 0;
		let lastScrollY = 0;
		let vortexScrollSpin = 0;
		let vortexScrollVelocity = 0;
		const mouseOffset = { x: 0, y: 0 };
		const targetMouseOffset = { x: 0, y: 0 };

		const onPointerMoveOffset = (e: PointerEvent) => {
			targetMouseOffset.x = (e.clientX / window.innerWidth - 0.5) * 5; // Horizontal sway
			targetMouseOffset.y = (e.clientY / window.innerHeight - 0.5) * 5; // Vertical sway
		};

		window.addEventListener("pointermove", onPointerMoveOffset);

		let animationFrameId: number | null = null;
		let isRunning = false;

		const startAnimation = () => {
			if (isRunning) return;
			isRunning = true;
			animate();
		};

		const stopAnimation = () => {
			if (!isRunning) return;
			isRunning = false;
			if (animationFrameId !== null) {
				cancelAnimationFrame(animationFrameId);
				animationFrameId = null;
			}
		};

		const updateVortexRibbons = (time: number) => {
			vortexRibbons.forEach(ribbon => {
				for (let i = 0; i < ribbonPointCount; i++) {
					const level = i / (ribbonPointCount - 1);
					getVortexPosition(vortexConfig, narrowViewport, level, ribbon.offset, ribbon.radiusBias, ribbon.verticalOffset, time, ribbonPoint);
					const positionIndex = i * 3;
					ribbon.positions[positionIndex] = ribbonPoint.x;
					ribbon.positions[positionIndex + 1] = ribbonPoint.y;
					ribbon.positions[positionIndex + 2] = ribbonPoint.z;
				}
				ribbon.geometry.setPositions(ribbon.positions);
				ribbon.line.computeLineDistances();
				ribbon.material.opacity = ribbon.opacity;
			});
		};

		const animate = () => {
			if (!isRunning) return;
			if (!reduceMotion) {
				animationFrameId = requestAnimationFrame(animate);
			}
			idleTime += reduceMotion ? 0 : 0.0007; // Slowed down significantly (half of 0.0015)

			const signedScrollDelta = reduceMotion ? 0 : window.scrollY - lastScrollY;
			const scrollDelta = Math.abs(signedScrollDelta);
			lastScrollY = window.scrollY;
			const scrollFactor = 1 + Math.min(scrollDelta * 0.01, 2);
			if (!reduceMotion) {
				vortexScrollVelocity += THREE.MathUtils.clamp(signedScrollDelta * 0.0018, -0.22, 0.22);
				vortexScrollVelocity *= 0.88;
				vortexScrollSpin += vortexScrollVelocity;

				scrollProgress += (window.scrollY / 8000 - scrollProgress) * 0.05;

				mouseOffset.x += (targetMouseOffset.x - mouseOffset.x) * 0.05;
				mouseOffset.y += (targetMouseOffset.y - mouseOffset.y) * 0.05;
			}

			// Subtle perspective shift
			camera.position.x = mouseOffset.x * 0.8;
			camera.position.y = -mouseOffset.y * 0.8;
			camera.rotation.y = -mouseOffset.x * 0.02;
			camera.rotation.x = -mouseOffset.y * 0.02;

			const vortexTime = vortexScrollSpin + idleTime * (narrowViewport ? 0.52 : 0.62);
			updateVortexRibbons(vortexTime);

			// Update Meteors - only show front half
			meteors.forEach(m => {
				m.progress = (m.progress + m.speed * scrollFactor) % 1;
				const pos = getVortexPosition(vortexConfig, narrowViewport, m.progress + scrollProgress * 0.04, m.offset, m.radiusBias, m.verticalOffset, vortexScrollSpin + idleTime * 0.88, meteorPos);
				m.mesh.position.copy(pos);

				// Rotate to look along path
				const nextPos = getVortexPosition(
					vortexConfig,
					narrowViewport,
					(m.progress + 0.018) % 1,
					m.offset + 0.02,
					m.radiusBias,
					m.verticalOffset,
					vortexScrollSpin + idleTime * 0.88 + 0.025,
					meteorNextPos
				);
				m.mesh.lookAt(nextPos);

				// Visibility and Alpha via Uniforms
				const opacity = getDepthOpacity(vortexConfig, pos.z) * getContentFade(pos);
				const isVisible = opacity > 0.02;
				m.mesh.visible = isVisible;
				if (isVisible) {
					// @ts-ignore
					m.mesh.material.uniforms.opacity.value = 0.2 * opacity;
				}
			});

			// Update Orbiting Decorative Objects (now all in heroObjects and draggable)
			heroObjects.forEach(obj => {
				const objectSpinTime = vortexScrollSpin + idleTime * (narrowViewport ? 0.78 : 0.95) * (0.78 + obj.speed * 850);
				const pathPos = getVortexPosition(vortexConfig, narrowViewport, obj.vortexLevel, obj.pathOffset, obj.radiusBias, obj.verticalOffset, objectSpinTime, obj.targetPos);

				if (!obj.isDragging) {
					const distanceToPath = obj.mesh.position.distanceTo(pathPos);
					if (distanceToPath > 80) {
						obj.mesh.position.copy(pathPos);
					} else {
						obj.mesh.position.lerp(pathPos, 0.05);
					}

					// Individualized slow rotation
					if (!reduceMotion) {
						obj.mesh.rotation.x += obj.rotationSpeed.x * scrollFactor;
						obj.mesh.rotation.y += obj.rotationSpeed.y * scrollFactor;
						obj.mesh.rotation.z += obj.rotationSpeed.z * scrollFactor;
					}

					// Lerp scale back to baseScale (reuse tempVec3 to avoid GC)
					tempVec3.set(obj.baseScale, obj.baseScale, obj.baseScale);
					obj.mesh.scale.lerp(tempVec3, 0.1);
				} else {
					// Shrink effect when dragging
					const targetScale = obj.baseScale * 0.7; // Shrink to 70%
					tempVec3.set(targetScale, targetScale, targetScale);
					obj.mesh.scale.lerp(tempVec3, 0.1);
				}

				// Scale visibility based on Z position for smooth fade
				const opacity = getDepthOpacity(vortexConfig, obj.mesh.position.z) * getContentFade(obj.mesh.position);
				const isVisible = opacity > 0.02;
				obj.mesh.visible = isVisible;
				const meshWithMaterial = obj.mesh as THREE.Mesh;
				if (isVisible && meshWithMaterial.material instanceof THREE.MeshPhysicalMaterial) {
					meshWithMaterial.material.opacity = opacity;
					meshWithMaterial.material.transparent = opacity < 0.98;
					meshWithMaterial.material.depthWrite = opacity >= 0.98;
				}
			});

			renderer.render(scene, camera);

			if (reduceMotion) {
				isRunning = false;
				animationFrameId = null;
			}
		};

		const onResize = () => {
			camera.aspect = window.innerWidth / window.innerHeight;
			camera.updateProjectionMatrix();
			renderer.setSize(window.innerWidth, window.innerHeight);
			vortexRibbons.forEach(ribbon => {
				ribbon.material.resolution.set(window.innerWidth, window.innerHeight);
			});
		};

		window.addEventListener("resize", onResize);

		startAnimation();

		// Stop animation when hero-container is out of view
		const heroObserver = new IntersectionObserver(
			entries => {
				const entry = entries[0];
				if (!entry) return;

				if (entry.isIntersecting) {
					// Hero is visible, start animation
					startAnimation();
				} else {
					// Hero is not visible, stop animation to save resources
					stopAnimation();
				}
			},
			{ threshold: 0 }
		);
		heroObserver.observe(heroContainer);

		const disposeScene = () => {
			scene.traverse(obj => {
				const mesh = obj as THREE.Mesh;
				if (mesh.geometry) {
					mesh.geometry.dispose();
				}
				if (mesh.material) {
					const materials = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
					materials.forEach(mat => {
						mat.dispose();
					});
				}
			});
		};

		return () => {
			stopAnimation();
			window.removeEventListener("pointerdown", onPointerDown);
			window.removeEventListener("pointermove", onPointerMove);
			window.removeEventListener("pointerup", onPointerUp);
			window.removeEventListener("pointermove", onPointerMoveOffset);
			window.removeEventListener("resize", onResize);
			heroObserver.disconnect();
			disposeScene();
			environmentRenderTarget.dispose();
			environmentScene.clear();
			pmremGenerator.dispose();
			renderer.dispose();
			heroContainer.dataset.heroInit = "false";
		};
	};

	let cleanup: (() => void) | null = null;
	const mount = () => {
		cleanup?.();
		cleanup = initHeroBackground();
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", mount, { once: true });
	} else {
		mount();
	}

	const pageLoadHandler = () => mount();
	const beforeSwapHandler = () => {
		cleanup?.();
		document.removeEventListener("astro:page-load", pageLoadHandler);
		document.removeEventListener("astro:before-swap", beforeSwapHandler);
	};

	document.addEventListener("astro:page-load", pageLoadHandler);
	document.addEventListener("astro:before-swap", beforeSwapHandler);
</script>
