---
import GridPerson from "./GridPerson.astro";
const { index, member, name, description } = Astro.props;
---

<div class="team" id={`team-${index}`}>
	<h2 class="text-reveal-title">{name}</h2>
	<p class="text text-reveal-paragraph">{description}</p>

	<div class="person-group">
		{
			member.map((person: { name: string; position: string; avatar_url: string; link?: string; description?: string; mode?: string; color?: string }) => (
				<GridPerson
					team={name}
					name={person.name}
					position={person.position}
					avatar_url={person.avatar_url}
					link={person.link}
					description={person.description}
					mode={person.mode}
					color={person.color}
				/>
			))
		}
	</div>
</div>

<style>
	.team {
		margin-bottom: clamp(4rem, 8vw, 7rem);
	}

	h2 {
		margin-bottom: 1rem;
		font-size: clamp(2rem, 4.5vw, 3.5rem);
		color: var(--metal-cream);
		line-height: 1.14;
		padding-bottom: 0.06em;
		overflow: visible;
	}

	h2 :global(.text-reveal-content),
	h2 :global(.text-reveal-content-mask) {
		line-height: 1.14 !important;
	}

	.text {
		max-width: 40rem;
		margin-bottom: 2rem;
		color: var(--metal-muted);
		line-height: 1.75;
	}

	.person-group {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(9.5rem, 11rem));
		align-items: start;
		justify-content: start;
		gap: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 3vw, 2rem);
	}

	.person-group :global(.person) {
		width: 100%;
		max-width: none;
		min-width: 0;
	}

	.person-group :global(.avatar-container) {
		margin-inline: auto;
	}

	.person-group :global(.text-group) {
		flex-direction: column;
		align-items: center;
		justify-content: flex-start;
		text-align: center;
		gap: 0.25rem;
		min-width: 0;
	}

	.person-group :global(.name),
	.person-group :global(.position) {
		width: 100%;
		line-height: 1.3;
		overflow-wrap: anywhere;
	}

	@media (max-width: 640px) {
		.person-group {
			grid-template-columns: repeat(auto-fill, minmax(8rem, 1fr));
			gap: 1.5rem 1rem;
		}
	}
</style>
