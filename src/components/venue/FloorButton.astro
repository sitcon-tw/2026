---
interface Props {
	id: string;
	label: string;
	description: string;
}

const { id, label, description } = Astro.props;
---

<button class="floor-btn" data-floor={id}>
	<div class="floor-badge">{label}</div>
	<div class="floor-info">
		<div class="floor-name">{label}</div>
		<div class="floor-desc">{description}</div>
	</div>
</button>

<style>
	.floor-btn {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: linear-gradient(145deg, rgba(255, 244, 214, 0.12), rgba(20, 19, 15, 0.42));
		border: 1px solid rgba(242, 216, 148, 0.28);
		border-radius: 0.5rem;
		padding: 1.2rem;
		cursor: pointer;
		text-align: left;
		color: var(--metal-cream);
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
		box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.18);
		width: 100%;
		backdrop-filter: blur(0.75rem);
	}

	.floor-btn:hover {
		background: linear-gradient(145deg, rgba(255, 244, 214, 0.2), rgba(20, 19, 15, 0.36));
		border-color: rgba(242, 216, 148, 0.52);
		transform: translateY(-0.125rem);
	}

	.floor-badge {
		background: linear-gradient(145deg, var(--metal-gold-soft), var(--metal-bronze));
		color: var(--metal-ink);
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.5rem;
		font-weight: 800;
		font-size: 1.5rem;
		flex-shrink: 0;
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
	}

	.floor-info {
		display: flex;
		flex-direction: column;
	}

	.floor-name {
		font-size: 1.8rem;
		font-weight: 700;
		line-height: 1.2;
		color: var(--metal-cream);
	}

	.floor-desc {
		font-size: 1rem;
		color: rgba(244, 239, 229, 0.72);
		margin-top: 0.2rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.floor-btn {
			transition: none;
		}
	}
</style>
