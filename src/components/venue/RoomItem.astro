---
interface Props {
	name: string;
	description: string;
	badge?: string;
	meshes?: string[];
	link?: string;
	longDescription?: string;
}

const { name, description, badge, meshes, link, longDescription } = Astro.props;
---

<div class="room-item" data-meshes={meshes ? JSON.stringify(meshes) : undefined} data-link={link ?? ""} data-long-description={longDescription ?? ""}>
	{badge && <div class="room-badge">{badge}</div>}
	<div class="room-info">
		<div class="room-name">{name}</div>
		<div class="room-desc">{description}</div>
	</div>
	{(link || longDescription) && <div class="room-chevron">›</div>}
</div>

<style>
	.room-item {
		display: flex;
		align-items: center;
		gap: 1rem;
		background: linear-gradient(145deg, rgba(255, 244, 214, 0.1), rgba(20, 19, 15, 0.38));
		border: 1px solid rgba(242, 216, 148, 0.22);
		border-radius: 0.5rem;
		padding: 1rem;
		cursor: pointer;
		transition:
			background 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
		width: 100%;
		color: var(--metal-cream);
		backdrop-filter: blur(0.75rem);
	}

	.room-item:hover {
		background: linear-gradient(145deg, rgba(255, 244, 214, 0.18), rgba(20, 19, 15, 0.34));
		border-color: rgba(242, 216, 148, 0.46);
		transform: translateY(-0.075rem);
	}

	.room-item.active {
		background: linear-gradient(145deg, rgba(242, 216, 148, 0.22), rgba(141, 99, 48, 0.22));
		border-color: rgba(242, 216, 148, 0.68);
	}

	.room-badge {
		background: linear-gradient(145deg, var(--metal-gold-soft), var(--metal-bronze));
		color: var(--metal-ink);
		width: 45px;
		height: 45px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.5rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.room-info {
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.room-name {
		font-size: 1.3rem;
		font-weight: 700;
		color: var(--metal-cream);
	}

	.room-desc {
		font-size: 0.9rem;
		color: rgba(244, 239, 229, 0.7);
	}

	.room-chevron {
		font-size: 1.6rem;
		opacity: 0.5;
		margin-left: 0.5rem;
		flex-shrink: 0;
		line-height: 1;
	}

	.room-item:hover .room-chevron {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.room-item {
			transition: none;
		}
	}
</style>
