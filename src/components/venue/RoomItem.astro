---
interface Props {
	name: string;
	description: string;
	badge?: string;
	meshes?: string[];
	link?: string;
	longDescription?: string;
}

const { name, description, badge, meshes, link, longDescription } = Astro.props;
---

<div class="room-item" data-meshes={meshes ? JSON.stringify(meshes) : undefined} data-link={link ?? ""} data-long-description={longDescription ?? ""}>
	{badge && <div class="room-badge">{badge}</div>}
	<div class="room-info">
		<div class="room-name">{name}</div>
		<div class="room-desc">{description}</div>
	</div>
	{(link || longDescription) && <div class="room-chevron">›</div>}
</div>

<style>
	.room-item {
		display: flex;
		align-items: center;
		background: rgba(255, 255, 255, 0.05);
		border: 2px solid white;
		border-radius: 16px;
		padding: 1rem;
		cursor: pointer;
		transition: all 0.2s;
		width: 100%;
	}

	.room-item:hover {
		background: rgba(255, 255, 255, 0.15);
	}

	.room-item.active {
		background: rgba(255, 221, 68, 0.2);
		border-color: #ffdd44;
	}

	.room-badge {
		background: #22c55e;
		color: white;
		width: 45px;
		height: 45px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 10px;
		font-weight: 700;
		margin-right: 1.2rem;
		flex-shrink: 0;
	}

	.room-info {
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.room-name {
		font-size: 1.3rem;
		font-weight: 700;
	}

	.room-desc {
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.room-chevron {
		font-size: 1.6rem;
		opacity: 0.5;
		margin-left: 0.5rem;
		flex-shrink: 0;
		line-height: 1;
	}

	.room-item:hover .room-chevron {
		opacity: 1;
	}
</style>
