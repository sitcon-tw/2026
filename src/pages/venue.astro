---
import Layout from "@/layout/Layout.astro";
// import { ShieldAlert } from "lucide-astro";
import FloorButton from "@/components/venue/FloorButton.astro";
import RoomItem from "@/components/venue/RoomItem.astro";
import floors from "@/data/venue.json";
import { useTranslations } from "@/utils/i18n";

const lang = Astro.props.lang ?? "zh";
const t = useTranslations(lang).venue;
---

<Layout title={lang === "en" ? "Venue Map - SITCON 2026" : "會場地圖 - SITCON 2026"} lang={lang}>
	<main>
		<div class="venue-container">
			<h1 class="title">{t.title}</h1>

			<div class="content-wrapper">
				<button id="sheet-toggle" class="sheet-toggle" aria-label="展開/收合選單">
					<span class="sheet-chevron"></span>
				</button>

				<!-- Floor Selection -->
				<div id="floor-selection" class="menu-panel">
					<p class="hint">{t.selectFloor}</p>
					<div class="floor-buttons" data-lenis-prevent>
						{floors.map(floor => <FloorButton id={floor.id} label={floor.label} description={floor.description} />)}
					</div>
				</div>

				<!-- Advanced Menu -->
				<div id="advanced-menu" class="menu-panel hidden">
					<div class="back-btn-wrapper">
						<button id="back-btn" class="back-btn">
							<span class="arrow">&lt;</span>
							{t.backToFloor}
						</button>
					</div>

					{
						floors.map(floor => (
							<div id={`room-list-${floor.id}`} class="room-list-container hidden">
								<div class="room-list" data-lenis-prevent>
									{floor.items.map(item => (
										<div class="room-item-wrapper">
											<RoomItem name={item.name} description={item.description} meshes={item.meshes} link={item.link} longDescription={item.longDescription} />
										</div>
									))}
								</div>
							</div>
						))
					}
				</div>

				<!-- Detail Panel -->
				<div id="detail-panel" class="menu-panel hidden">
					<div class="back-btn-wrapper">
						<button id="detail-back-btn" class="back-btn">
							<span class="arrow">&lt;</span>
							{t.backToList}
						</button>
					</div>
					<div id="detail-content" class="detail-content" data-lenis-prevent>
						<h2 id="detail-name" class="detail-name"></h2>
						<p id="detail-badge" class="detail-badge"></p>
						<p id="detail-long-desc" class="detail-long-desc"></p>
						<a id="detail-link-btn" class="detail-link-btn" href="#" target="_blank" rel="noopener noreferrer">{t.visitWebsite}</a>
					</div>
				</div>
			</div>

			<!-- Emergency Exit -->
			<div class="emergency-btn-container">
				<button id="explode-toggle-btn" class="explode-btn">&#9776; 分層檢視</button>
				<a class="emergency-btn" href="https://hackmd.io/@SITCON/H1J2-d3y6" target="_blank">
					<!-- <ShieldAlert size={20} /> -->
					{t.emergency}
				</a>
			</div>

			<button id="toggle-2d-btn" class="toggle-2d-btn" type="button" aria-label="切換 2D 檢視">2D</button>

			<dialog id="map-2d-overlay" class="map-2d-overlay" aria-label="2D 平面圖">
				<div class="map-2d-popup" role="dialog" aria-modal="true" aria-label="2D 平面圖">
					<div class="map-2d-image-wrapper">
						<div class="map-2d-top-controls">
							<div class="map-floor-switch" role="group" aria-label="切換樓層平面圖">
								<button class="map-floor-btn active" type="button" data-map-floor="3f" aria-pressed="true">3F</button>
								<button class="map-floor-btn" type="button" data-map-floor="4f" aria-pressed="false">4F</button>
							</div>
							<button id="map-2d-close-btn" class="map-2d-close-btn" type="button" aria-label="關閉 2D 平面圖">×</button>
						</div>
						<img class="map-2d-image" src="/2026/img/venue/map_3F.svg" alt="3F 場地平面圖" draggable="false" />
					</div>
				</div>
			</dialog>

			<!-- 3D Canvas -->
			<canvas id="venue-canvas"></canvas>
		</div>
	</main>
</Layout>

<style>
	main {
		width: 100%;
		height: 100vh;
		overflow: hidden;
		background-color: #a67c37;
		color: white;
		position: relative;
	}

	#venue-canvas {
		position: absolute;
		top: 0;
		right: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
	}

	.venue-container {
		position: relative;
		width: 100%;
		height: 100%;
		padding: 8rem 4rem 4rem;
		display: flex;
		flex-direction: column;
		z-index: 1;
	}

	.title {
		text-align: center;
		font-size: 4rem;
		margin-bottom: 1rem;
		font-family: "GenKiMinTW", serif;
		font-weight: 700;
		position: relative;
		z-index: 100;
	}

	.content-wrapper {
		position: relative;
		flex: 1;
		display: flex;
		align-items: flex-start;
		margin-top: 1rem;
		min-height: 400px; /* Added min-height */
	}

	.menu-panel {
		width: 380px;
		z-index: 10;
		position: relative;
		display: flex;
		flex-direction: column;
		max-height: 100%;
	}

	.menu-panel.hidden {
		display: none;
		pointer-events: none;
	}

	.floor-btn,
	.room-item-wrapper,
	.back-btn,
	.hint {
		will-change: transform, opacity;
	}

	.floor-buttons {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		overflow-y: auto;
		flex: 1;
		scrollbar-width: none;
	}

	.hint {
		font-size: 1.4rem;
		opacity: 0.9;
		font-weight: 500;
	}

	.back-btn-wrapper {
		height: 3.5rem;
		display: flex;
		align-items: center;
	}

	.back-btn {
		background: none;
		border: none;
		color: white;
		cursor: pointer;
		font-size: 1.1rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		opacity: 0.9;
		transition: opacity 0.2s;
	}

	.back-btn:hover {
		opacity: 1;
	}

	.room-list-container {
		flex: 1;
		min-height: 0;
		display: flex;
		flex-direction: column;
	}

	.room-list-container.hidden {
		display: none;
	}

	.room-list {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		flex: 1;
		overflow-y: auto;
		padding-right: 1rem;
		padding-bottom: 1rem;
	}

	.room-item-wrapper {
		width: 100%;
	}

	/* Custom Scrollbar */
	.room-list::-webkit-scrollbar,
	.floor-buttons::-webkit-scrollbar {
		width: 6px;
	}
	.room-list::-webkit-scrollbar-track,
	.floor-buttons::-webkit-scrollbar-track {
		background: rgba(255, 255, 255, 0.1);
		border-radius: 3px;
	}
	.room-list::-webkit-scrollbar-thumb,
	.floor-buttons::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.3);
		border-radius: 3px;
	}

	.detail-content {
		flex: 1;
		overflow-y: auto;
		padding-right: 0.5rem;
		padding-bottom: 1rem;
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		scrollbar-width: none;
	}

	.detail-content::-webkit-scrollbar {
		width: 6px;
	}
	.detail-content::-webkit-scrollbar-track {
		background: rgba(255, 255, 255, 0.1);
		border-radius: 3px;
	}
	.detail-content::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.3);
		border-radius: 3px;
	}

	.detail-name {
		font-size: 1.6rem;
		font-weight: 700;
		line-height: 1.3;
		font-family: "GenKiMinTW", serif;
	}

	.detail-badge {
		font-size: 0.9rem;
		opacity: 0.7;
		margin: 0;
	}

	.detail-long-desc {
		font-size: 1rem;
		line-height: 1.7;
		opacity: 0.9;
		margin: 0;
	}

	.detail-link-btn {
		display: inline-flex;
		align-items: center;
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.5);
		color: white;
		padding: 0.6rem 1.2rem;
		border-radius: 30px;
		font-size: 1rem;
		text-decoration: none;
		cursor: pointer;
		transition: background 0.2s;
		width: fit-content;
		backdrop-filter: blur(4px);
	}

	.detail-link-btn:hover {
		background: rgba(255, 255, 255, 0.25);
	}

	.detail-link-btn.hidden {
		display: none;
	}

	/* Sheet toggle button — hidden on desktop, shown on mobile */
	.sheet-toggle {
		display: none;
	}

	.emergency-btn-container {
		margin-top: 2rem;
		z-index: 10;
		display: flex;
		gap: 0.8rem;
		align-items: center;
	}

	.explode-btn {
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.4);
		color: white;
		padding: 0.6rem 1.2rem;
		border-radius: 30px;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		cursor: pointer;
		font-size: 1rem;
		transition:
			background 0.2s,
			border-color 0.2s;
		backdrop-filter: blur(4px);
	}

	.explode-btn:hover {
		background: rgba(255, 255, 255, 0.25);
	}

	.explode-btn.active {
		background: rgba(255, 255, 255, 0.3);
		border-color: white;
	}

	.emergency-btn {
		background: rgba(0, 0, 0, 0.3);
		border: none;
		color: white;
		padding: 0.6rem 1.2rem;
		border-radius: 30px;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		cursor: pointer;
		font-size: 1rem;
		transition: background 0.2s;
		backdrop-filter: blur(4px);
	}

	.emergency-btn:hover {
		background: rgba(0, 0, 0, 0.5);
	}

	.toggle-2d-btn {
		position: fixed;
		right: 1.25rem;
		bottom: max(1.25rem, env(safe-area-inset-bottom, 1.25rem));
		width: 3.25rem;
		height: 3.25rem;
		border-radius: 50%;
		border: 0.0625rem solid transparent;
		background: rgba(0, 0, 0, 0.52);
		color: #fff;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		backdrop-filter: blur(0.375rem);
		-webkit-backdrop-filter: blur(0.375rem);
		z-index: 9999;
		transition:
			background 0.2s ease,
			transform 0.2s ease;
	}

	.toggle-2d-btn:hover {
		background: rgba(0, 0, 0, 0.68);
		transform: translateY(-0.0625rem);
	}

	.toggle-2d-btn:active {
		transform: translateY(0);
	}

	.toggle-2d-btn:focus-visible {
		outline: 0.125rem solid #fff;
		outline-offset: 0.125rem;
	}

	.map-2d-overlay {
		display: none;
		border: none;
		padding: 0;
		margin: 0;
		background: transparent;
		color: white;
		width: 100%;
		max-width: none;
		height: 100%;
		max-height: none;
		position: fixed;
		inset: 0;
		z-index: 10000;
	}

	.map-2d-overlay[open] {
		display: grid;
		place-items: center;
		padding: 1rem;
	}

	.map-2d-overlay::backdrop {
		background: rgba(0, 0, 0, 0.55);
		backdrop-filter: blur(0.1875rem);
		-webkit-backdrop-filter: blur(0.1875rem);
	}

	.map-2d-popup {
		position: fixed;
		top: 50%;
		left: 50%;
		width: min(50rem, calc(100vw - 2rem));
		height: min(80vh, calc(100vh - 2rem));
		border-radius: 1rem;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		background: rgba(0, 0, 0, 0.44);
		margin: 1rem 0;
		box-shadow: 0 1.375rem 3.125rem rgba(0, 0, 0, 0.45);
		transform: translate(-50%, -50%) translateY(0.625rem) scale(0.98);
		transition: transform 0.2s ease;
	}

	.map-2d-overlay.show .map-2d-popup {
		transform: translate(-50%, -50%) translateY(0) scale(1);
	}

	.map-2d-close-btn {
		position: static;
		z-index: 3;
		width: 2.25rem;
		height: 2.25rem;
		border: none;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.52);
		color: white;
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
	}

	.map-2d-close-btn:hover {
		background: rgba(0, 0, 0, 0.65);
	}

	.map-2d-image-wrapper {
		position: relative;
		flex: 1;
		min-height: 0;
		background: #0f0f0f;
		overflow: hidden;
		display: grid;
		place-items: center;
	}

	.map-2d-top-controls {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		z-index: 3;
	}

	.map-floor-switch {
		display: inline-flex;
		padding: 0.2rem;
		border-radius: 999px;
		background: rgba(18, 18, 18, 0.38);
		border: 1px solid rgba(255, 255, 255, 0.22);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
	}

	.map-floor-btn {
		border: none;
		background: transparent;
		color: rgba(255, 255, 255, 0.82);
		font-size: 0.85rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		padding: 0.3rem 0.65rem;
		border-radius: 999px;
		cursor: pointer;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}

	.map-floor-btn:hover {
		color: #fff;
	}

	.map-floor-btn.active {
		background: rgba(255, 255, 255, 0.22);
		color: #fff;
	}

	.map-2d-image {
		width: 100%;
		height: auto;
		max-height: 100%;
		display: block;
		user-select: none;
		-webkit-user-select: none;
	}

	@media (max-width: 1024px) {
		/* Canvas covers full screen */
		#venue-canvas {
			height: 100%;
			top: 0;
			bottom: auto;
		}

		/* Bottom-sheet layout */
		.venue-container {
			padding: 0;
			justify-content: flex-end;
		}

		.title {
			display: none;
		}

		/*
		 * Two bugs fixed vs previous attempt:
		 * 1. z-index: 5 — canvas (z-index:0) is later in DOM, so without
		 *    an explicit z-index here it paints over the sheet background.
		 * 2. height: 52vh (not just max-height) — flex children that use
		 *    flex:1 need a resolved parent height or they collapse to 0.
		 */
		.content-wrapper {
			position: relative;
			z-index: 5;
			flex: 0 0 auto;
			flex-direction: column;
			align-items: stretch;
			height: 52vh;
			min-height: auto;
			width: 100%;
			background: rgba(140, 100, 38, 0.92);
			backdrop-filter: blur(18px);
			-webkit-backdrop-filter: blur(18px);
			border-radius: 18px 18px 0 0;
			padding: 1.2rem 1.2rem 0;
			margin-top: 0;
			/* No overflow:hidden — it blocks touch-scroll on iOS Safari for children */
		}

		/* Smooth height transition for expand/collapse */
		.content-wrapper {
			transition: height 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		}

		/* Expand/collapse toggle button */
		.sheet-toggle {
			display: flex;
			align-items: center;
			justify-content: center;
			flex-shrink: 0;
			align-self: center;
			width: 44px;
			height: 26px;
			margin-bottom: 0.7rem;
			background: rgba(255, 255, 255, 0.15);
			border: none;
			border-radius: 13px;
			cursor: pointer;
			padding: 0;
		}

		.sheet-chevron {
			display: block;
			width: 8px;
			height: 8px;
			border-right: 2px solid rgba(255, 255, 255, 0.85);
			border-bottom: 2px solid rgba(255, 255, 255, 0.85);
			transform: rotate(45deg) translate(-1px, -1px); /* points ▼ = can collapse */
			transition: transform 0.3s ease;
		}

		/* When sheet is collapsed, chevron flips to ▲ = can expand */
		.sheet-toggle.collapsed .sheet-chevron {
			transform: rotate(-135deg) translate(-1px, -1px);
		}

		/* Each panel fills the sheet — min-height:0 is critical: without it the
		   flex child's min-height defaults to content size, making room-list
		   unbounded (nothing to scroll). */
		.menu-panel {
			flex: 1;
			min-height: 0;
			width: 100%;
			max-width: 100%;
			max-height: none;
			z-index: 20;
		}

		.hint {
			font-size: 1.1rem;
			margin-bottom: 0.4rem;
		}

		/* Let flex:1 from base styles fill the panel naturally */
		.floor-buttons {
			max-height: none;
		}

		/* Scrollable list areas: smooth touch scroll, contained overscroll.
		   overscroll-behavior:contain stops the pull-to-refresh propagation
		   at the list boundary so it never reaches the page level. */
		.floor-buttons,
		.room-list,
		.detail-content {
			touch-action: pan-y;
			overscroll-behavior: contain;
		}

		/* Emergency buttons share the same glass style */
		.emergency-btn-container {
			position: relative;
			z-index: 5;
			margin-top: 0;
			padding: 0.5rem 1.2rem;
			padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0.75rem));
			background: rgba(140, 100, 38, 0.92);
			backdrop-filter: blur(18px);
			-webkit-backdrop-filter: blur(18px);
			gap: 0.5rem;
			flex-wrap: wrap;
		}

		.toggle-2d-btn {
			right: 1rem;
			bottom: max(1rem, env(safe-area-inset-bottom, 1rem));
			width: 3rem;
			height: 3rem;
		}

		.map-2d-overlay[open] {
			padding: 3.5rem;
		}

		.map-2d-image-wrapper {
			touch-action: none;
			overflow: auto;
			scrollbar-width: none;
			overscroll-behavior: contain;
		}

		.map-2d-image-wrapper::-webkit-scrollbar {
			display: none;
		}

		.map-2d-popup {
			top: 50%;
			left: 50%;
			width: calc(100vw - 7rem);
			height: calc(100vh - 7rem);
			transform: translate(-50%, -50%) translateY(0.625rem) scale(0.98);
		}

		.map-2d-overlay.show .map-2d-popup {
			transform: translate(-50%, -50%) translateY(0) scale(1);
		}
	}

	@media (max-width: 640px) {
		.content-wrapper {
			height: 56vh;
			padding: 1rem 1rem 0;
		}

		.hint {
			font-size: 1rem;
		}

		.back-btn-wrapper {
			height: 3rem;
		}

		.floor-buttons {
			gap: 0.8rem;
		}

		.room-list {
			padding-right: 0.4rem;
			gap: 0.8rem;
		}

		.detail-name {
			font-size: 1.3rem;
		}

		.detail-long-desc {
			font-size: 0.95rem;
		}

		.emergency-btn-container {
			padding: 0.4rem 1rem;
			padding-bottom: max(0.5rem, env(safe-area-inset-bottom, 0.5rem));
		}
	}
</style>

<script>
	import gsap from "gsap";
	import * as THREE from "three";
	import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";
	import { OrbitControls } from "three/addons/controls/OrbitControls.js";

	// Single unified model — floors are identified by mesh name prefix: main.<floorId>.*
	const MODEL_PATH = "/2026/models/researchcentermodelv5.glb";

	// Floor IDs must match the folder names in the GLB (lowercase), ordered bottom → top
	const FLOOR_IDS = ["1f", "2f", "3f", "4f"];

	// Direct children of "main" that are always visible (not floor-specific)
	const SHARED_NAMES = ["elevators", "outside"];

	// Gap between floors in world units when stacked (adjusted for model scale at runtime)
	let FLOOR_GAP_LOCAL = 20;
	const CAMERA_ANGLE = Math.PI / -3;

	let scene: THREE.Scene;
	let camera: THREE.PerspectiveCamera;
	let renderer: THREE.WebGLRenderer;
	let controls: OrbitControls;
	// One Object3D per floor — meshes are re-parented here with baked world transforms
	let floorPivots: Map<string, THREE.Object3D> = new Map();
	// Shared pivot for elevators/outside
	let sharedPivot: THREE.Object3D;
	let currentFloor: string | null = null;
	let isExploded = false;
	let animationId: number;
	let modelGroup: THREE.Group;

	// Mesh name → Mesh lookup built after model loads
	const meshByName = new Map<string, THREE.Mesh>();
	// Track currently highlighted meshes and their original emissive colors
	const highlightedMeshes = new Map<string, THREE.Color>();
	const HIGHLIGHT_COLOR = new THREE.Color(0xffdd44);

	// Raycaster for 3D picking
	const raycaster = new THREE.Raycaster();
	const mouse = new THREE.Vector2();

	// Set by initVenue so canvas click can trigger detail panel
	let showDetailFn: ((el: Element) => void) | null = null;

	// Cleanup function returned by initSheetToggle
	let sheetCleanup: (() => void) | null = null;
	// Cleanup function returned by 2D popup binding
	let popupCleanup: (() => void) | null = null;

	const prefersReducedMotion = () => window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	/**
	 * On mobile the bottom sheet covers part of the canvas.
	 * setViewOffset shifts the projection frustum downward so the model
	 * is visually centred in the visible area above the menu.
	 * Reads actual DOM height so it stays correct when the sheet is dragged.
	 */
	const updateViewOffset = () => {
		if (!camera || !renderer) return;
		const W = renderer.domElement.width;
		const H = renderer.domElement.height;
		if (window.innerWidth <= 1024) {
			const wrapper = document.querySelector(".content-wrapper") as HTMLElement | null;
			const emergencyBtns = document.querySelector(".emergency-btn-container") as HTMLElement | null;
			const menuHeight = (wrapper?.getBoundingClientRect().height ?? 0) + (emergencyBtns?.getBoundingClientRect().height ?? 0);
			const menuFraction = menuHeight / window.innerHeight;
			camera.setViewOffset(W, H, 0, Math.round(H * menuFraction * 0.5), W, H);
		} else {
			camera.clearViewOffset();
		}
		camera.updateProjectionMatrix();
	};

	const initSheetToggle = (): (() => void) => {
		if (window.innerWidth > 1024) return () => {};

		const toggle = document.getElementById("sheet-toggle") as HTMLButtonElement | null;
		const wrapper = document.querySelector(".content-wrapper") as HTMLElement | null;
		if (!toggle || !wrapper) return () => {};

		const EXPANDED_VH = window.innerWidth <= 640 ? 56 : 52;
		const COLLAPSED_VH = 25;
		let expanded = true;

		const onToggle = () => {
			expanded = !expanded;
			wrapper.style.height = `${expanded ? EXPANDED_VH : COLLAPSED_VH}vh`;
			toggle.classList.toggle("collapsed", !expanded);
			updateViewOffset();
		};

		// main already has overflow:hidden so the page can't scroll.
		// overscroll-behavior:none on body kills the rubber-band / pull-to-refresh
		// without any touchmove listener — which would interfere with menu scroll.
		const prevOverscroll = document.body.style.overscrollBehavior;
		document.body.style.overscrollBehavior = "none";

		toggle.addEventListener("click", onToggle);

		return () => {
			toggle.removeEventListener("click", onToggle);
			document.body.style.overscrollBehavior = prevOverscroll;
		};
	};

	const initThree = () => {
		const canvas = document.getElementById("venue-canvas") as HTMLCanvasElement;
		if (!canvas) return;

		// Scene
		scene = new THREE.Scene();
		scene.background = new THREE.Color(0xa67c37);

		// Camera
		const canvasRect = canvas.getBoundingClientRect();
		camera = new THREE.PerspectiveCamera(45, canvasRect.width / canvasRect.height, 0.1, 1000);
		camera.position.set(0, 6, 8);
		camera.lookAt(0, 0, 0);

		// Renderer
		renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
		renderer.setSize(canvasRect.width, canvasRect.height);
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 3));
		renderer.shadowMap.enabled = true;
		renderer.shadowMap.type = THREE.PCFSoftShadowMap;

		// Controls
		controls = new OrbitControls(camera, renderer.domElement);
		controls.enableDamping = true;
		controls.dampingFactor = 0.05;
		controls.minDistance = 0;
		controls.maxDistance = 100;
		controls.maxPolarAngle = Math.PI / 2;
		controls.target.set(0, 1, 0);

		// Lighting
		const ambientLight = new THREE.AmbientLight(0xffffff, 0.7);
		scene.add(ambientLight);

		const directionalLight = new THREE.DirectionalLight(0xffffff, 1.2);
		directionalLight.position.set(5, 10, 5);
		directionalLight.castShadow = true;
		directionalLight.shadow.mapSize.width = 4096;
		directionalLight.shadow.mapSize.height = 4096;
		directionalLight.shadow.camera.near = 0.1;
		directionalLight.shadow.camera.far = 50;
		directionalLight.shadow.camera.left = -10;
		directionalLight.shadow.camera.right = 10;
		directionalLight.shadow.camera.top = 10;
		directionalLight.shadow.camera.bottom = -10;
		directionalLight.shadow.bias = -0.001;
		scene.add(directionalLight);

		const fillLight = new THREE.DirectionalLight(0xffffff, 0.4);
		fillLight.position.set(-5, 5, -5);
		scene.add(fillLight);

		// Root group for the entire model (for rotation/scale/centering)
		modelGroup = new THREE.Group();
		modelGroup.rotation.y = CAMERA_ANGLE;
		scene.add(modelGroup);

		loadModel();
		updateViewOffset();

		window.addEventListener("resize", onWindowResize);
		renderer.domElement.addEventListener("pointerdown", onCanvasPointerDown);
		renderer.domElement.addEventListener("click", onCanvasClick);
		renderer.domElement.addEventListener("pointermove", onCanvasPointerMove);
		animate();
	};

	/** Re-parent a mesh into target, preserving its current world transform. */
	const attachWithWorldTransform = (mesh: THREE.Mesh, target: THREE.Object3D) => {
		mesh.updateWorldMatrix(true, false);
		const wp = new THREE.Vector3();
		const wq = new THREE.Quaternion();
		const ws = new THREE.Vector3();
		mesh.matrixWorld.decompose(wp, wq, ws);
		target.add(mesh);
		mesh.position.copy(wp);
		mesh.quaternion.copy(wq);
		mesh.scale.copy(ws);
	};

	const loadModel = () => {
		const loader = new GLTFLoader();
		loader.load(
			MODEL_PATH,
			gltf => {
				// Collect meshes per floor/shared first, then re-parent after traverse
				const buckets = new Map<string, THREE.Mesh[]>();
				FLOOR_IDS.forEach(fid => buckets.set(fid, []));
				const sharedBucket: THREE.Mesh[] = [];

				// Force world matrices to be up to date before we read them
				gltf.scene.updateMatrixWorld(true);

				gltf.scene.traverse(obj => {
					if (!(obj instanceof THREE.Mesh)) return;
					obj.castShadow = true;
					obj.receiveShadow = true;
					// Clone materials so opacity changes on one mesh don't affect others sharing the same material
					if (obj.material) {
						const cloneMat = (mat: THREE.Material) => {
							const m = mat.clone() as THREE.MeshStandardMaterial;
							const baseOpacity = (m as THREE.MeshStandardMaterial).opacity ?? 1;
							m.transparent = true;
							if (baseOpacity < 0.99) {
								// Window-like material: preserve original alpha, fix depth/side issues
								m.depthWrite = false;
								m.side = THREE.DoubleSide;
								m.userData = { ...m.userData, baseOpacity };
							} else {
								m.opacity = 1;
								m.userData = { ...m.userData, baseOpacity: 1 };
							}
							return m;
						};
						if (Array.isArray(obj.material)) {
							obj.material = obj.material.map(cloneMat);
						} else {
							obj.material = cloneMat(obj.material);
						}
					}
					const n = obj.name.toLowerCase();
					const matchedFloor = FLOOR_IDS.find(fid => n.startsWith(`floor__${fid}__`));
					const isShared = SHARED_NAMES.some(sn => n.startsWith(`floor__${sn}__`));
					if (matchedFloor) buckets.get(matchedFloor)!.push(obj);
					else if (isShared) sharedBucket.push(obj);
				});

				// Create one pivot Object3D per floor + one for shared, all under modelGroup
				FLOOR_IDS.forEach(fid => {
					const pivot = new THREE.Object3D();
					pivot.name = `pivot_${fid}`;
					modelGroup.add(pivot);
					floorPivots.set(fid, pivot);
				});

				sharedPivot = new THREE.Object3D();
				sharedPivot.name = "pivot_shared";
				modelGroup.add(sharedPivot);

				// Re-parent meshes into their pivot with baked world transforms
				buckets.forEach((meshes, fid) => {
					const pivot = floorPivots.get(fid)!;
					meshes.forEach(m => attachWithWorldTransform(m, pivot));
				});
				sharedBucket.forEach(m => attachWithWorldTransform(m, sharedPivot));

				console.log("Floors:", [...floorPivots.entries()].map(([k, v]) => `${k}(${v.children.length})`).join(", "), "| shared:", sharedPivot.children.length);

				centerAndScaleModel();
				buildMeshIndex();
				showAllFloorsCollapsed();
			},
			undefined,
			error => console.error("Error loading model:", error)
		);
	};

	const centerAndScaleModel = () => {
		// Temporarily add all pivots to measure total bounding box
		const box = new THREE.Box3().setFromObject(modelGroup);
		const center = box.getCenter(new THREE.Vector3());
		const size = box.getSize(new THREE.Vector3());

		modelGroup.position.x = -center.x + 2;
		modelGroup.position.z = -center.z;

		const maxDim = Math.max(size.x, size.y, size.z);
		modelGroup.scale.setScalar(8 / maxDim);

		// FLOOR_GAP_LOCAL is in pivot local space (pivots are direct children of modelGroup)
		// modelGroup scale is 8/maxDim, so 1 local unit = (8/maxDim) world units
		// We want ~2 world units gap → local gap = 2 / (8/maxDim) = maxDim/4
		FLOOR_GAP_LOCAL = maxDim / 4;
	};

	const setPivotOpacity = (pivot: THREE.Object3D, opacity: number, duration: number, onComplete?: () => void) => {
		const meshes: THREE.Mesh[] = [];
		pivot.traverse(c => {
			if (c instanceof THREE.Mesh && c.material && !c.userData.isOutline) meshes.push(c);
		});
		meshes.forEach((mesh, i) => {
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (!("opacity" in mat)) return;
				// Preserve window material's original alpha (e.g. 0.3) — only scale it by the fade factor
				const baseOpacity = (mat as THREE.MeshStandardMaterial).userData?.baseOpacity ?? 1;
				const target = opacity * baseOpacity;
				gsap.killTweensOf(mat);
				if (duration === 0) {
					(mat as THREE.MeshStandardMaterial).opacity = target;
				} else {
					gsap.to(mat, {
						opacity: target,
						duration,
						onComplete: onComplete && i === meshes.length - 1 ? onComplete : undefined
					});
				}
			});
		});
		if (duration === 0 && onComplete) onComplete();
	};

	const showAllFloorsCollapsed = () => {
		currentFloor = null;
		isExploded = false;
		const rm = prefersReducedMotion();

		floorPivots.forEach(pivot => {
			pivot.visible = true;
			gsap.killTweensOf(pivot.position);
			if (rm) pivot.position.y = 0;
			else gsap.to(pivot.position, { y: 0, duration: 0.8, ease: "power2.inOut" });
			setPivotOpacity(pivot, 1, rm ? 0 : 0.5);
		});

		sharedPivot.visible = true;
		gsap.killTweensOf(sharedPivot.position);
		if (rm) sharedPivot.position.y = 0;
		else gsap.to(sharedPivot.position, { y: 0, duration: 0.8, ease: "power2.inOut" });
		setPivotOpacity(sharedPivot, 1, rm ? 0 : 0.5);

		if (rm) {
			camera.position.set(-8, 6, 8);
			controls.target.set(0, 1.5, 0);
		} else {
			gsap.to(camera.position, { x: -8, y: 6, z: 8, duration: 1, ease: "power2.inOut" });
			gsap.to(controls.target, { x: 0, y: 1.5, z: 0, duration: 1, ease: "power2.inOut" });
		}
	};

	const showAllFloorsStacked = () => {
		currentFloor = null;
		isExploded = true;
		const rm = prefersReducedMotion();

		floorPivots.forEach((pivot, fid) => {
			const yOffset = FLOOR_IDS.indexOf(fid) * FLOOR_GAP_LOCAL;
			pivot.visible = true;
			gsap.killTweensOf(pivot.position);
			if (rm) {
				pivot.position.y = yOffset;
			} else {
				gsap.to(pivot.position, { y: yOffset, duration: 0.8, ease: "power2.inOut" });
			}
			setPivotOpacity(pivot, 1, rm ? 0 : 0.5);
		});

		// Hide shared (elevators/outside) in exploded view — they'd look weird floating
		setPivotOpacity(sharedPivot, 0, rm ? 0 : 0.4, () => {
			sharedPivot.visible = false;
		});
		if (rm) sharedPivot.visible = false;

		if (rm) {
			camera.position.set(-8, 10, 10);
			controls.target.set(0, 2, 0);
		} else {
			gsap.to(camera.position, { x: -8, y: 10, z: 10, duration: 1, ease: "power2.inOut" });
			gsap.to(controls.target, { x: 0, y: 2, z: 0, duration: 1, ease: "power2.inOut" });
		}
	};

	const showSingleFloor = (floorId: string) => {
		const normalizedId = floorId.toLowerCase();
		currentFloor = normalizedId;
		const floorIndex = FLOOR_IDS.indexOf(normalizedId);
		const rm = prefersReducedMotion();

		floorPivots.forEach((pivot, fid) => {
			gsap.killTweensOf(pivot.position);
			if (fid === normalizedId) {
				pivot.visible = true;
				if (rm) pivot.position.y = 0;
				else gsap.to(pivot.position, { y: 0, duration: 0.6, ease: "power2.inOut" });
				setPivotOpacity(pivot, 1, rm ? 0 : 0.4);
			} else {
				setPivotOpacity(pivot, 0, rm ? 0 : 0.3, () => {
					pivot.visible = false;
				});
				if (rm) pivot.visible = false;
			}
		});

		// Hide shared on single-floor view
		setPivotOpacity(sharedPivot, 0, rm ? 0 : 0.3, () => {
			sharedPivot.visible = false;
		});
		if (rm) sharedPivot.visible = false;

		const cameraY = 4 + floorIndex * 0.3;
		if (rm) {
			camera.position.set(-6, cameraY, 6);
			controls.target.set(0, 0.5, 0);
		} else {
			gsap.to(camera.position, { x: -6, y: cameraY, z: 6, duration: 1, ease: "power2.inOut" });
			gsap.to(controls.target, { x: 0, y: 0.5, z: 0, duration: 1, ease: "power2.inOut" });
		}
	};

	const buildMeshIndex = () => {
		modelGroup.traverse(obj => {
			if (obj instanceof THREE.Mesh) meshByName.set(obj.name.toLowerCase(), obj);
		});
	};

	// ── Hover state ──────────────────────────────────────────────────────────
	let hoveredMesh: THREE.Mesh | null = null;
	// Meshes currently tinted by hover (may be a whole floor pivot's meshes)
	const hoveredMeshOriginals = new Map<THREE.Mesh, THREE.Color>();
	const HOVER_COLOR = new THREE.Color(0xffffff);

	const applyHoverTint = (meshes: THREE.Mesh[]) => {
		meshes.forEach(mesh => {
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (mat instanceof THREE.MeshStandardMaterial && !highlightedMeshes.has(mesh.name.toLowerCase())) {
					hoveredMeshOriginals.set(mesh, mat.emissive.clone());
					mat.emissive.copy(HOVER_COLOR);
					mat.emissiveIntensity = 0.15;
				}
			});
		});
	};

	const clearHoverTint = () => {
		hoveredMeshOriginals.forEach((originalEmissive, mesh) => {
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (mat instanceof THREE.MeshStandardMaterial && !highlightedMeshes.has(mesh.name.toLowerCase())) {
					mat.emissive.copy(originalEmissive);
					mat.emissiveIntensity = 0;
				}
			});
		});
		hoveredMeshOriginals.clear();
	};

	let hoveredFloorId: string | null = null;

	const setMeshHover = (mesh: THREE.Mesh | null, floorId?: string | null) => {
		const nextFloor = floorId ?? null;
		// Skip if nothing changed
		if (mesh === hoveredMesh && nextFloor === hoveredFloorId) return;
		clearHoverTint();
		hoveredFloorId = nextFloor;
		hoveredMesh = mesh;

		if (floorId) {
			// Highlight all meshes of the floor pivot
			const pivot = floorPivots.get(floorId);
			if (pivot) {
				const meshes: THREE.Mesh[] = [];
				pivot.traverse(c => {
					if (c instanceof THREE.Mesh) meshes.push(c);
				});
				applyHoverTint(meshes);
			}
		} else if (mesh) {
			applyHoverTint([mesh]);
		}
	};

	/** Get the floor ID a mesh belongs to based on its name prefix. */
	const getFloorIdFromMesh = (mesh: THREE.Mesh): string | null => {
		const n = mesh.name.toLowerCase();
		return FLOOR_IDS.find(fid => n.startsWith(`floor__${fid}__`)) ?? null;
	};

	/** Returns true if the object and all its ancestors are visible. */
	const isFullyVisible = (obj: THREE.Object3D): boolean => {
		let cur: THREE.Object3D | null = obj;
		while (cur) {
			if (!cur.visible) return false;
			cur = cur.parent;
		}
		return true;
	};

	/** Pick the topmost fully-visible mesh under the pointer. */
	const pickMesh = (event: MouseEvent | PointerEvent): THREE.Mesh | null => {
		const canvas = renderer.domElement;
		const rect = canvas.getBoundingClientRect();
		mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
		mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
		raycaster.setFromCamera(mouse, camera);
		const hits = raycaster.intersectObject(modelGroup, true);
		for (const hit of hits) {
			if (hit.object instanceof THREE.Mesh && isFullyVisible(hit.object)) return hit.object;
		}
		return null;
	};

	const zoomToMeshes = (names: string[]) => {
		const box = new THREE.Box3();
		names.forEach(rawName => {
			const mesh = meshByName.get(rawName.toLowerCase());
			if (mesh) box.expandByObject(mesh);
		});
		if (box.isEmpty()) return;
		const center = box.getCenter(new THREE.Vector3());
		const size = box.getSize(new THREE.Vector3());
		const maxDim = Math.max(size.x, size.y, size.z);
		// Position camera so object fills view nicely
		const fov = camera.fov * (Math.PI / 180);
		const dist = (maxDim / 2 / Math.tan(fov / 2)) * 2.2;
		const offset = new THREE.Vector3(-dist * 0.6, dist * 0.5, dist * 0.8).normalize().multiplyScalar(dist);
		const rm = prefersReducedMotion();
		if (rm) {
			camera.position.copy(center).add(offset);
			controls.target.copy(center);
		} else {
			gsap.to(camera.position, { x: center.x + offset.x, y: center.y + offset.y, z: center.z + offset.z, duration: 0.8, ease: "power2.inOut" });
			gsap.to(controls.target, { x: center.x, y: center.y, z: center.z, duration: 0.8, ease: "power2.inOut" });
		}
	};

	/** Called by the UI's room-item click to also zoom the camera. */
	const selectRoomItem = (meshNames: string[]) => {
		highlightMeshes(meshNames);
		zoomToMeshes(meshNames);
	};

	// Track pointer-down position to distinguish click from drag
	let pointerDownX = 0;
	let pointerDownY = 0;
	const onCanvasPointerDown = (e: PointerEvent) => {
		pointerDownX = e.clientX;
		pointerDownY = e.clientY;
	};

	/** Fired when the canvas is clicked. */
	const onCanvasClick = (event: MouseEvent) => {
		// Ignore if pointer moved more than 5px (orbit drag)
		if (Math.hypot(event.clientX - pointerDownX, event.clientY - pointerDownY) > 5) return;
		// No interaction when on the floor-selection overview (not exploded, no floor selected)
		if (!isExploded && !currentFloor) return;

		const mesh = pickMesh(event);

		if (!mesh) {
			// Clicked empty space in single-floor view — deselect
			if (currentFloor) {
				clearHighlight();
				document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
			}
			return;
		}

		if (isExploded && !currentFloor) {
			// ── Layered view: clicking a floor navigates into it ──
			const floorId = getFloorIdFromMesh(mesh);
			if (floorId) {
				// Mimic clicking the floor button
				const floorBtn = document.querySelector(`.floor-btn[data-floor="${floorId}"]`) as HTMLElement | null;
				floorBtn?.click();
			}
			return;
		}

		if (currentFloor) {
			// ── Single-floor view: clicking a mesh selects it ──
			const n = mesh.name.toLowerCase();
			// Find matching room item by checking its data-meshes list
			const roomItems = document.querySelectorAll(".room-item");
			let matched: Element | null = null;
			roomItems.forEach(el => {
				const raw = el.getAttribute("data-meshes");
				if (!raw) return;
				const names: string[] = JSON.parse(raw);
				if (names.map(s => s.toLowerCase()).includes(n)) matched = el;
			});

			if (!matched) {
				// Clicked empty area — deselect
				clearHighlight();
				document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
				return;
			}

			if (matched) {
				showDetailFn?.(matched);
				(matched as HTMLElement).scrollIntoView({ behavior: "smooth", block: "nearest" });
			}
		}
	};

	/** Fired on pointer move for hover effect. */
	const onCanvasPointerMove = (event: PointerEvent) => {
		// No interaction when on the floor-selection overview
		if (!isExploded && !currentFloor) {
			renderer.domElement.style.cursor = "grab";
			setMeshHover(null, null);
			return;
		}

		const mesh = pickMesh(event as unknown as MouseEvent);

		if (isExploded && !currentFloor) {
			// Highlight the entire floor on hover
			const floorId = mesh ? getFloorIdFromMesh(mesh) : null;
			renderer.domElement.style.cursor = floorId ? "pointer" : "grab";
			setMeshHover(mesh, floorId);
			return;
		}

		if (currentFloor) {
			// Only highlight meshes that belong to a room item
			let actionable = false;
			if (mesh) {
				const n = mesh.name.toLowerCase();
				document.querySelectorAll(".room-item").forEach(el => {
					const raw = el.getAttribute("data-meshes");
					if (!raw) return;
					const names: string[] = JSON.parse(raw);
					if (names.map(s => s.toLowerCase()).includes(n)) actionable = true;
				});
			}
			renderer.domElement.style.cursor = actionable ? "pointer" : "grab";
			setMeshHover(actionable ? mesh : null, null);
		}
	};

	// ── Outline (inverted-hull) for selected meshes ──────────────────────────
	const outlineMeshes = new Map<string, THREE.Mesh>();
	const OUTLINE_COLOR = new THREE.Color(0xffdd44);
	const OUTLINE_THICKNESS = 0.008;

	const addOutline = (mesh: THREE.Mesh) => {
		if (outlineMeshes.has(mesh.name)) return;
		const outlineMat = new THREE.MeshBasicMaterial({
			color: OUTLINE_COLOR,
			side: THREE.BackSide,
			transparent: true,
			opacity: 0,
			depthWrite: false,
			polygonOffset: true,
			polygonOffsetFactor: -4,
			polygonOffsetUnits: -4
		});
		const outline = new THREE.Mesh(mesh.geometry, outlineMat);
		// As a child of mesh: identity position/rotation, just scale up uniformly
		outline.scale.setScalar(1 + OUTLINE_THICKNESS);
		outline.userData.isOutline = true;
		outline.raycast = () => {}; // make it non-pickable
		mesh.add(outline);
		outlineMeshes.set(mesh.name, outline);
		gsap.to(outlineMat, { opacity: 1, duration: 0.3, ease: "power2.out" });
	};

	const removeOutlines = () => {
		outlineMeshes.forEach((outline, meshName) => {
			const mat = outline.material as THREE.MeshBasicMaterial;
			const parentMesh = meshByName.get(meshName.toLowerCase());
			gsap.to(mat, {
				opacity: 0,
				duration: 0.2,
				onComplete: () => {
					(parentMesh ?? outline.parent)?.remove(outline);
					mat.dispose();
				}
			});
		});
		outlineMeshes.clear();
	};

	const clearHighlight = () => {
		highlightedMeshes.forEach((originalColor, meshName) => {
			const mesh = meshByName.get(meshName);
			if (!mesh) return;
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (mat instanceof THREE.MeshStandardMaterial) {
					gsap.killTweensOf(mat.emissive);
					gsap.killTweensOf(mat);
					mat.emissive.copy(originalColor);
					mat.emissiveIntensity = 0;
				}
			});
		});
		highlightedMeshes.clear();
		removeOutlines();
	};

	const highlightMeshes = (names: string[]) => {
		clearHighlight();
		names.forEach(rawName => {
			const name = rawName.toLowerCase();
			const mesh = meshByName.get(name);
			if (!mesh) return;
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (!(mat instanceof THREE.MeshStandardMaterial)) return;
				// Save original emissive before first highlight
				if (!highlightedMeshes.has(name)) {
					highlightedMeshes.set(name, mat.emissive.clone());
				}
				mat.emissive.copy(HIGHLIGHT_COLOR);
				gsap.killTweensOf(mat);
				gsap.fromTo(mat, { emissiveIntensity: 0.2 }, { emissiveIntensity: 0.5, duration: 0.8, ease: "sine.inOut", yoyo: true, repeat: -1 });
			});
			addOutline(mesh);
		});
	};

	const onWindowResize = () => {
		const canvas = document.getElementById("venue-canvas") as HTMLCanvasElement;
		if (!canvas) return;
		const canvasRect = canvas.getBoundingClientRect();
		camera.aspect = canvasRect.width / canvasRect.height;
		renderer.setSize(canvasRect.width, canvasRect.height);
		updateViewOffset(); // re-applies offset (also calls updateProjectionMatrix)
	};

	const animate = () => {
		animationId = requestAnimationFrame(animate);
		controls.update();
		renderer.render(scene, camera);
	};

	const cleanup = () => {
		showDetailFn = null;
		sheetCleanup?.();
		sheetCleanup = null;
		popupCleanup?.();
		popupCleanup = null;
		if (animationId) cancelAnimationFrame(animationId);
		window.removeEventListener("resize", onWindowResize);
		renderer?.domElement.removeEventListener("pointerdown", onCanvasPointerDown);
		renderer?.domElement.removeEventListener("click", onCanvasClick);
		renderer?.domElement.removeEventListener("pointermove", onCanvasPointerMove);

		modelGroup?.traverse((child: THREE.Object3D) => {
			if (child instanceof THREE.Mesh) {
				child.geometry?.dispose();
				const mats = Array.isArray(child.material) ? child.material : [child.material];
				mats.forEach((m: THREE.Material) => m.dispose());
			}
		});

		floorPivots.clear();
		meshByName.clear();
		highlightedMeshes.clear();
		renderer?.dispose();
		controls?.dispose();
	};

	const initVenue = () => {
		const floorSelection = document.getElementById("floor-selection");
		const advancedMenu = document.getElementById("advanced-menu");
		const backBtn = document.getElementById("back-btn");
		const floorBtns = document.querySelectorAll(".floor-btn");
		const roomListContainers = document.querySelectorAll(".room-list-container");
		const hint = document.querySelector(".hint");
		const toggle2DBtn = document.getElementById("toggle-2d-btn") as HTMLButtonElement | null;
		const map2DOverlay = document.getElementById("map-2d-overlay") as HTMLDialogElement | null;
		const map2DCloseBtn = document.getElementById("map-2d-close-btn") as HTMLButtonElement | null;
		const map2DImage = document.querySelector(".map-2d-image") as HTMLImageElement | null;
		const mapFloorBtns = document.querySelectorAll(".map-floor-btn");
		const map2DImageWrapper = document.querySelector(".map-2d-image-wrapper") as HTMLElement | null;

		if (!floorSelection || !advancedMenu || !backBtn) return;

		let lastActiveElement: HTMLElement | null = null;
		const previousBodyOverflow = document.body.style.overflow;
		const mapPaths: Record<"3f" | "4f", string> = {
			"3f": "/2026/img/venue/map_3F.svg",
			"4f": "/2026/img/venue/map_4F.svg"
		};
		const mapMinScale = 1;
		const mapMaxScale = 4;
		let mapScale = 1;
		const activePointers = new Map<number, { x: number; y: number }>();
		let panStart = { x: 0, y: 0 };
		let panBaseScroll = { left: 0, top: 0 };
		let pinchStartDistance = 0;
		let pinchStartScale = 1;

		const isMobileViewport = () => window.innerWidth <= 1024;

		const clamp = (value: number, min: number, max: number) => Math.min(max, Math.max(min, value));

		const applyMapZoom = () => {
			if (!map2DImage) return;
			const zoomPercent = `${mapScale * 100}%`;
			map2DImage.style.width = zoomPercent;
			map2DImage.style.maxHeight = mapScale > 1 ? "none" : "100%";
		};

		const resetMapTransform = () => {
			mapScale = 1;
			activePointers.clear();
			pinchStartDistance = 0;
			applyMapZoom();
			if (map2DImageWrapper) {
				map2DImageWrapper.scrollLeft = 0;
				map2DImageWrapper.scrollTop = 0;
			}
		};

		const getPointerDistance = () => {
			const points = Array.from(activePointers.values());
			if (points.length < 2) return 0;
			const dx = points[0].x - points[1].x;
			const dy = points[0].y - points[1].y;
			return Math.hypot(dx, dy);
		};

		const setMapFloor = (floorId: string) => {
			const normalized = floorId.toLowerCase() === "4f" ? "4f" : "3f";
			if (map2DImage) {
				map2DImage.src = mapPaths[normalized];
				map2DImage.alt = `${normalized.toUpperCase()} 場地平面圖`;
			}
			resetMapTransform();
			mapFloorBtns.forEach(btn => {
				const isActive = btn.getAttribute("data-map-floor") === normalized;
				btn.classList.toggle("active", isActive);
				btn.setAttribute("aria-pressed", String(isActive));
			});
		};

		const open2DPopup = () => {
			if (!map2DOverlay) return;
			setMapFloor(currentFloor === "4f" ? "4f" : "3f");
			lastActiveElement = document.activeElement as HTMLElement | null;
			if (typeof map2DOverlay.showModal === "function") {
				map2DOverlay.showModal();
			} else {
				map2DOverlay.setAttribute("open", "");
			}
			map2DOverlay.classList.add("show");
			document.body.style.overflow = "hidden";
		};

		const close2DPopup = () => {
			if (!map2DOverlay) return;
			map2DOverlay.classList.remove("show");
			if (typeof map2DOverlay.close === "function" && map2DOverlay.hasAttribute("open")) {
				map2DOverlay.close();
			} else {
				map2DOverlay.removeAttribute("open");
			}
			document.body.style.overflow = previousBodyOverflow;
			if (lastActiveElement && typeof lastActiveElement.focus === "function") {
				lastActiveElement.focus();
			}
			resetMapTransform();
		};

		const onOverlayClick = (e: Event) => {
			if (e.target === map2DOverlay) close2DPopup();
		};

		const onEscapeKey = (e: KeyboardEvent) => {
			if (e.key === "Escape" && map2DOverlay?.classList.contains("show")) {
				close2DPopup();
			}
		};

		const onMapFloorClick = (e: Event) => {
			const btn = e.currentTarget as HTMLButtonElement;
			const floorId = btn.getAttribute("data-map-floor");
			if (!floorId) return;
			setMapFloor(floorId);
		};

		const onMapPointerDown = (e: PointerEvent) => {
			if (!isMobileViewport() || !map2DImageWrapper || e.pointerType !== "touch") return;
			e.preventDefault();
			map2DImageWrapper.setPointerCapture(e.pointerId);
			activePointers.set(e.pointerId, { x: e.clientX, y: e.clientY });

			if (activePointers.size === 1) {
				panStart = { x: e.clientX, y: e.clientY };
				panBaseScroll = { left: map2DImageWrapper.scrollLeft, top: map2DImageWrapper.scrollTop };
			}

			if (activePointers.size >= 2) {
				pinchStartDistance = getPointerDistance();
				pinchStartScale = mapScale;
			}
		};

		const onMapPointerMove = (e: PointerEvent) => {
			if (!isMobileViewport() || e.pointerType !== "touch") return;
			if (!activePointers.has(e.pointerId)) return;
			e.preventDefault();
			activePointers.set(e.pointerId, { x: e.clientX, y: e.clientY });

			if (activePointers.size >= 2) {
				const nextDistance = getPointerDistance();
				if (pinchStartDistance > 0) {
					mapScale = clamp((nextDistance / pinchStartDistance) * pinchStartScale, mapMinScale, mapMaxScale);
					const beforeW = map2DImage.scrollWidth;
					const beforeH = map2DImage.scrollHeight;
					const centerXRatio = beforeW > 0 ? (map2DImageWrapper.scrollLeft + map2DImageWrapper.clientWidth / 2) / beforeW : 0.5;
					const centerYRatio = beforeH > 0 ? (map2DImageWrapper.scrollTop + map2DImageWrapper.clientHeight / 2) / beforeH : 0.5;
					applyMapZoom();
					const afterW = map2DImage.scrollWidth;
					const afterH = map2DImage.scrollHeight;
					map2DImageWrapper.scrollLeft = Math.max(0, afterW * centerXRatio - map2DImageWrapper.clientWidth / 2);
					map2DImageWrapper.scrollTop = Math.max(0, afterH * centerYRatio - map2DImageWrapper.clientHeight / 2);
				}
				return;
			}

			if (mapScale <= mapMinScale) return;
			map2DImageWrapper.scrollLeft = panBaseScroll.left - (e.clientX - panStart.x);
			map2DImageWrapper.scrollTop = panBaseScroll.top - (e.clientY - panStart.y);
		};

		const onMapPointerUp = (e: PointerEvent) => {
			if (!isMobileViewport() || !map2DImageWrapper || e.pointerType !== "touch") return;
			if (!activePointers.has(e.pointerId)) return;
			e.preventDefault();
			activePointers.delete(e.pointerId);
			if (map2DImageWrapper.hasPointerCapture(e.pointerId)) {
				map2DImageWrapper.releasePointerCapture(e.pointerId);
			}

			if (activePointers.size === 1) {
				const [remainingPointer] = Array.from(activePointers.values());
				panStart = { x: remainingPointer.x, y: remainingPointer.y };
				panBaseScroll = { left: map2DImageWrapper.scrollLeft, top: map2DImageWrapper.scrollTop };
			}

			if (activePointers.size < 2) {
				pinchStartDistance = 0;
				pinchStartScale = mapScale;
			}
		};

		const onMapPointerCancel = (e: PointerEvent) => {
			onMapPointerUp(e);
		};

		toggle2DBtn?.addEventListener("click", open2DPopup);
		map2DCloseBtn?.addEventListener("click", close2DPopup);
		map2DOverlay?.addEventListener("click", onOverlayClick);
		document.addEventListener("keydown", onEscapeKey);
		mapFloorBtns.forEach(btn => btn.addEventListener("click", onMapFloorClick));
		map2DImageWrapper?.addEventListener("pointerdown", onMapPointerDown, { passive: false });
		map2DImageWrapper?.addEventListener("pointermove", onMapPointerMove, { passive: false });
		map2DImageWrapper?.addEventListener("pointerup", onMapPointerUp, { passive: false });
		map2DImageWrapper?.addEventListener("pointercancel", onMapPointerCancel, { passive: false });

		popupCleanup?.();
		popupCleanup = () => {
			toggle2DBtn?.removeEventListener("click", open2DPopup);
			map2DCloseBtn?.removeEventListener("click", close2DPopup);
			map2DOverlay?.removeEventListener("click", onOverlayClick);
			document.removeEventListener("keydown", onEscapeKey);
			mapFloorBtns.forEach(btn => btn.removeEventListener("click", onMapFloorClick));
			map2DImageWrapper?.removeEventListener("pointerdown", onMapPointerDown);
			map2DImageWrapper?.removeEventListener("pointermove", onMapPointerMove);
			map2DImageWrapper?.removeEventListener("pointerup", onMapPointerUp);
			map2DImageWrapper?.removeEventListener("pointercancel", onMapPointerCancel);
			if (map2DOverlay?.hasAttribute("open")) map2DOverlay.close();
			document.body.style.overflow = previousBodyOverflow;
			resetMapTransform();
		};

		// Initial state for floor buttons
		gsap.set(".floor-btn", { opacity: 1, y: 0 });
		if (hint) gsap.set(hint, { opacity: 0.9, y: 0 });

		floorBtns.forEach(btn => {
			btn.addEventListener("click", () => {
				const floorId = btn.getAttribute("data-floor");
				if (floorId) showFloor(floorId);
			});
		});

		const explodeToggleBtn = document.getElementById("explode-toggle-btn");
		if (explodeToggleBtn) {
			explodeToggleBtn.addEventListener("click", () => {
				if (isExploded) {
					showAllFloorsCollapsed();
					explodeToggleBtn.classList.remove("active");
				} else {
					showAllFloorsStacked();
					explodeToggleBtn.classList.add("active");
				}
			});
		}

		backBtn.addEventListener("click", () => {
			clearHighlight();
			showSelection();
		});

		// Detail panel elements
		const detailPanel = document.getElementById("detail-panel");
		const detailBackBtn = document.getElementById("detail-back-btn");

		const showDetail = (itemEl: Element) => {
			const name = itemEl.querySelector(".room-name")?.textContent ?? "";
			const badge = itemEl.querySelector(".room-desc")?.textContent ?? "";
			const longDescription = itemEl.getAttribute("data-long-description") ?? "";
			const link = itemEl.getAttribute("data-link") ?? "";
			const meshesRaw = itemEl.getAttribute("data-meshes");
			const meshNames: string[] = meshesRaw ? JSON.parse(meshesRaw) : [];

			// Mark active
			document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
			itemEl.classList.add("active");

			// 3D highlight
			clearHighlight();
			selectRoomItem(meshNames);

			// Populate panel
			const nameEl = document.getElementById("detail-name");
			const badgeEl = document.getElementById("detail-badge");
			const longDescEl = document.getElementById("detail-long-desc");
			const linkBtn = document.getElementById("detail-link-btn") as HTMLAnchorElement | null;
			if (nameEl) nameEl.textContent = name;
			if (badgeEl) badgeEl.textContent = badge;
			if (longDescEl) longDescEl.textContent = longDescription;
			if (linkBtn) {
				if (link) {
					linkBtn.href = link;
					linkBtn.classList.remove("hidden");
				} else {
					linkBtn.classList.add("hidden");
				}
			}

			const isDetailVisible = !detailPanel?.classList.contains("hidden");
			if (isDetailVisible) {
				// Already in detail panel — just update content with a quick flash
				const tl = gsap.timeline();
				tl.to("#detail-content", { opacity: 0, duration: 0.15, ease: "power2.in" });
				tl.to("#detail-content", { opacity: 1, duration: 0.2, ease: "power2.out" });
				return;
			}

			// Animate: room list → detail panel
			const activeRoomList = document.querySelector(".room-list-container:not(.hidden)");
			const tl = gsap.timeline();
			if (activeRoomList) {
				tl.to(activeRoomList.querySelectorAll(".room-item-wrapper"), {
					opacity: 0,
					x: -20,
					duration: 0.25,
					stagger: { each: 0.04, from: "end" },
					ease: "power2.in"
				});
				tl.to("#back-btn", { opacity: 0, x: -10, duration: 0.2 }, "<");
			}
			tl.add(() => {
				advancedMenu?.classList.add("hidden");
				detailPanel?.classList.remove("hidden");
			});
			tl.fromTo("#detail-back-btn", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.3, ease: "power2.out" });
			tl.fromTo("#detail-content", { opacity: 0, y: 16 }, { opacity: 1, y: 0, duration: 0.35, ease: "power2.out" }, "-=0.1");
		};

		showDetailFn = showDetail;

		const showRoomList = () => {
			const targetRoomList = currentFloor ? document.getElementById(`room-list-${currentFloor}`) : null;
			const tl = gsap.timeline();
			tl.to("#detail-content", { opacity: 0, y: 16, duration: 0.2, ease: "power2.in" });
			tl.to("#detail-back-btn", { opacity: 0, x: -10, duration: 0.15 }, "<");
			tl.add(() => {
				detailPanel?.classList.add("hidden");
				advancedMenu?.classList.remove("hidden");
				if (targetRoomList) targetRoomList.classList.remove("hidden");
			});
			tl.fromTo("#back-btn", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.3, ease: "power2.out" });
			if (targetRoomList) {
				tl.fromTo(targetRoomList.querySelectorAll(".room-item-wrapper"), { opacity: 0, x: -20 }, { opacity: 1, x: 0, duration: 0.35, stagger: 0.05, ease: "power2.out" }, "-=0.1");
			}
		};

		if (detailBackBtn) {
			detailBackBtn.addEventListener("click", () => {
				clearHighlight();
				document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
				showRoomList();
			});
		}

		// Room item click → show detail
		document.querySelectorAll(".room-item").forEach(el => {
			el.addEventListener("click", () => {
				showDetail(el);
			});
		});

		const showFloor = (floorId: string) => {
			const targetRoomList = document.getElementById(`room-list-${floorId}`);
			if (!targetRoomList) return;

			// Update 3D view
			showSingleFloor(floorId);

			const tl = gsap.timeline();

			// 1. Exit Floor Selection
			tl.to(".floor-btn", {
				opacity: 0,
				y: 20,
				duration: 0.3,
				stagger: 0.05,
				ease: "power2.in"
			});
			if (hint) {
				tl.to(hint, { opacity: 0, y: 10, duration: 0.2 }, "<");
			}

			tl.add(() => {
				floorSelection?.classList.add("hidden");
				advancedMenu?.classList.remove("hidden");
				roomListContainers.forEach(container => container.classList.add("hidden"));
				targetRoomList.classList.remove("hidden");
			});

			// 2. Enter Advanced Menu
			tl.fromTo("#back-btn", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.4, ease: "power2.out" });

			tl.fromTo(
				targetRoomList.querySelectorAll(".room-item-wrapper"),
				{ opacity: 0, y: 30 },
				{
					opacity: 1,
					y: 0,
					duration: 0.5,
					stagger: 0.1,
					ease: "power2.out"
				},
				"-=0.3"
			);
		};

		const showSelection = () => {
			const activeRoomList = Array.from(roomListContainers).find(c => !c.classList.contains("hidden"));
			if (!activeRoomList) return;

			// Update 3D view — return to whichever overview mode was active
			if (isExploded) showAllFloorsStacked();
			else showAllFloorsCollapsed();

			const tl = gsap.timeline();

			// 1. Exit Advanced Menu
			tl.to(activeRoomList.querySelectorAll(".room-item-wrapper"), {
				opacity: 0,
				y: 30,
				duration: 0.3,
				stagger: {
					each: 0.05,
					from: "end"
				},
				ease: "power2.in"
			});

			tl.to("#back-btn", { opacity: 0, x: -10, duration: 0.2 }, "<");

			tl.add(() => {
				advancedMenu?.classList.add("hidden");
				floorSelection?.classList.remove("hidden");
			});

			// 2. Enter Floor Selection
			tl.fromTo(
				".floor-btn",
				{ opacity: 0, y: 20 },
				{
					opacity: 1,
					y: 0,
					duration: 0.4,
					stagger: 0.1,
					ease: "power2.out"
				}
			);
			if (hint) {
				tl.fromTo(hint, { opacity: 0, y: 10 }, { opacity: 0.9, y: 0, duration: 0.3 }, "-=0.2");
			}
		};

		sheetCleanup = initSheetToggle();
	};

	// Initialize Three.js
	initThree();

	// Run on initial load
	initVenue();

	// Run on View Transitions navigation
	document.addEventListener("astro:after-swap", () => {
		cleanup();
		initThree();
		initVenue();
	});

	// Cleanup on page unload
	document.addEventListener("astro:before-swap", cleanup);
</script>
