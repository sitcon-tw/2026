---
import Layout from "@/layout/Layout.astro";
// import { ShieldAlert } from "lucide-astro";
import FloorButton from "@/components/venue/FloorButton.astro";
import RoomItem from "@/components/venue/RoomItem.astro";
import floors from "@/data/venue.json";
import { useTranslations } from "@/utils/i18n";

const lang = Astro.props.lang ?? "zh";
const t = useTranslations(lang).venue;
---

<Layout title={lang === "en" ? "Venue Map - SITCON 2026" : "會場地圖 - SITCON 2026"} lang={lang}>
	<main>
		<div class="venue-container">
			<h1 class="title">{t.title}</h1>

			<div class="content-wrapper">
				<!-- Floor Selection -->
				<div id="floor-selection" class="menu-panel">
					<p class="hint">{t.selectFloor}</p>
					<div class="floor-buttons" data-lenis-prevent>
						{floors.map(floor => <FloorButton id={floor.id} label={floor.label} description={floor.description} />)}
					</div>
				</div>

				<!-- Advanced Menu -->
				<div id="advanced-menu" class="menu-panel hidden">
					<div class="back-btn-wrapper">
						<button id="back-btn" class="back-btn">
							<span class="arrow">&lt;</span>
							{t.backToFloor}
						</button>
					</div>

					{
						floors.map(floor => (
							<div id={`room-list-${floor.id}`} class="room-list-container hidden">
								<div class="room-list" data-lenis-prevent>
									{floor.items.map(item => (
										<div class="room-item-wrapper">
											<RoomItem name={item.name} description={item.description} meshes={item.meshes} />
										</div>
									))}
								</div>
							</div>
						))
					}
				</div>
			</div>

			<!-- Emergency Exit -->
			<div class="emergency-btn-container">
				<button id="explode-toggle-btn" class="explode-btn">&#9776; 分層檢視</button>
				<button class="emergency-btn">
					<!-- <ShieldAlert size={20} /> -->
					{t.emergency}
				</button>
			</div>

			<!-- 3D Canvas -->
			<canvas id="venue-canvas"></canvas>
		</div>
	</main>
</Layout>

<style>
	main {
		width: 100%;
		height: 100vh;
		overflow: hidden;
		background-color: #a67c37;
		color: white;
		position: relative;
	}

	#venue-canvas {
		position: absolute;
		top: 0;
		right: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
	}

	.venue-container {
		position: relative;
		width: 100%;
		height: 100%;
		padding: 6rem 4rem 4rem;
		display: flex;
		flex-direction: column;
		z-index: 1;
	}

	.title {
		text-align: center;
		font-size: 4rem;
		margin-bottom: 1rem;
		font-family: "GenKiMinTW", serif;
		font-weight: 700;
		position: relative;
		z-index: 100;
	}

	.content-wrapper {
		position: relative;
		flex: 1;
		display: flex;
		align-items: flex-start;
		margin-top: 1rem;
		min-height: 400px; /* Added min-height */
	}

	.menu-panel {
		width: 380px;
		z-index: 10;
		position: relative;
		display: flex;
		flex-direction: column;
		max-height: 100%;
	}

	.menu-panel.hidden {
		display: none;
		pointer-events: none;
	}

	.floor-btn,
	.room-item-wrapper,
	.back-btn,
	.hint {
		will-change: transform, opacity;
	}

	.floor-buttons {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		overflow-y: auto;
		flex: 1;
		scrollbar-width: none;
	}

	.hint {
		font-size: 1.4rem;
		opacity: 0.9;
		font-weight: 500;
	}

	.back-btn-wrapper {
		height: 3.5rem;
		display: flex;
		align-items: center;
	}

	.back-btn {
		background: none;
		border: none;
		color: white;
		cursor: pointer;
		font-size: 1.1rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		opacity: 0.9;
		transition: opacity 0.2s;
	}

	.back-btn:hover {
		opacity: 1;
	}

	.room-list-container {
		flex: 1;
		min-height: 0;
		display: flex;
		flex-direction: column;
	}

	.room-list-container.hidden {
		display: none;
	}

	.room-list {
		display: flex;
		flex-direction: column;
		gap: 1.2rem;
		flex: 1;
		overflow-y: auto;
		padding-right: 1rem;
		padding-bottom: 1rem;
	}

	.room-item-wrapper {
		width: 100%;
	}

	/* Custom Scrollbar */
	.room-list::-webkit-scrollbar,
	.floor-buttons::-webkit-scrollbar {
		width: 6px;
	}
	.room-list::-webkit-scrollbar-track,
	.floor-buttons::-webkit-scrollbar-track {
		background: rgba(255, 255, 255, 0.1);
		border-radius: 3px;
	}
	.room-list::-webkit-scrollbar-thumb,
	.floor-buttons::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.3);
		border-radius: 3px;
	}

	.emergency-btn-container {
		margin-top: 2rem;
		z-index: 10;
		display: flex;
		gap: 0.8rem;
		align-items: center;
	}

	.explode-btn {
		background: rgba(255, 255, 255, 0.15);
		border: 1px solid rgba(255, 255, 255, 0.4);
		color: white;
		padding: 0.6rem 1.2rem;
		border-radius: 30px;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		cursor: pointer;
		font-size: 1rem;
		transition:
			background 0.2s,
			border-color 0.2s;
		backdrop-filter: blur(4px);
	}

	.explode-btn:hover {
		background: rgba(255, 255, 255, 0.25);
	}

	.explode-btn.active {
		background: rgba(255, 255, 255, 0.3);
		border-color: white;
	}

	.emergency-btn {
		background: rgba(0, 0, 0, 0.3);
		border: none;
		color: white;
		padding: 0.6rem 1.2rem;
		border-radius: 30px;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		cursor: pointer;
		font-size: 1rem;
		transition: background 0.2s;
		backdrop-filter: blur(4px);
	}

	.emergency-btn:hover {
		background: rgba(0, 0, 0, 0.5);
	}

	@media (max-width: 1024px) {
		.venue-container {
			padding: 5rem 1.5rem 1.5rem;
		}
		.menu-panel {
			width: 100%;
			max-width: 100%;
			z-index: 20;
		}
		.title {
			font-size: 2.5rem;
		}

		.content-wrapper {
			flex-direction: column;
			min-height: auto;
			max-height: 40vh;
		}
		.floor-buttons {
			max-height: 30vh;
		}
		#venue-canvas {
			width: 100%;
			height: 50%;
			top: auto;
			bottom: 0;
			left: 0;
			right: 0;
		}
	}

	@media (max-width: 640px) {
		.venue-container {
			padding: 4.5rem 1rem 1rem;
		}
		.title {
			font-size: 2rem;
		}
		.hint {
			font-size: 1.1rem;
		}
		.floor-buttons {
			gap: 1rem;
		}
	}
</style>

<script>
	import gsap from "gsap";
	import * as THREE from "three";
	import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";
	import { OrbitControls } from "three/addons/controls/OrbitControls.js";

	// Single unified model — floors are identified by mesh name prefix: main.<floorId>.*
	const MODEL_PATH = "/2026/models/researchcentermodelv4.glb";

	// Floor IDs must match the folder names in the GLB (lowercase), ordered bottom → top
	const FLOOR_IDS = ["1f", "2f", "3f", "4f"];

	// Direct children of "main" that are always visible (not floor-specific)
	const SHARED_NAMES = ["elevators", "outside"];

	// Gap between floors in world units when stacked (adjusted for model scale at runtime)
	let FLOOR_GAP_LOCAL = 20;
	const CAMERA_ANGLE = Math.PI / -3;

	let scene: THREE.Scene;
	let camera: THREE.PerspectiveCamera;
	let renderer: THREE.WebGLRenderer;
	let controls: OrbitControls;
	// One Object3D per floor — meshes are re-parented here with baked world transforms
	let floorPivots: Map<string, THREE.Object3D> = new Map();
	// Shared pivot for elevators/outside
	let sharedPivot: THREE.Object3D;
	let currentFloor: string | null = null;
	let isExploded = false;
	let animationId: number;
	let modelGroup: THREE.Group;

	// Mesh name → Mesh lookup built after model loads
	const meshByName = new Map<string, THREE.Mesh>();
	// Track currently highlighted meshes and their original emissive colors
	const highlightedMeshes = new Map<string, THREE.Color>();
	const HIGHLIGHT_COLOR = new THREE.Color(0xffdd44);
	const HIGHLIGHT_EMISSIVE_INTENSITY = 2.0;

	// Raycaster for 3D picking
	const raycaster = new THREE.Raycaster();
	const mouse = new THREE.Vector2();

	const prefersReducedMotion = () => window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	const initThree = () => {
		const canvas = document.getElementById("venue-canvas") as HTMLCanvasElement;
		if (!canvas) return;

		// Scene
		scene = new THREE.Scene();
		scene.background = new THREE.Color(0xa67c37);

		// Camera
		const canvasRect = canvas.getBoundingClientRect();
		camera = new THREE.PerspectiveCamera(45, canvasRect.width / canvasRect.height, 0.1, 1000);
		camera.position.set(0, 6, 8);
		camera.lookAt(0, 0, 0);

		// Renderer
		renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
		renderer.setSize(canvasRect.width, canvasRect.height);
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 3));
		renderer.shadowMap.enabled = true;
		renderer.shadowMap.type = THREE.PCFSoftShadowMap;

		// Controls
		controls = new OrbitControls(camera, renderer.domElement);
		controls.enableDamping = true;
		controls.dampingFactor = 0.05;
		controls.minDistance = 0;
		controls.maxDistance = 100;
		controls.maxPolarAngle = Math.PI / 2;
		controls.target.set(0, 1, 0);

		// Lighting
		const ambientLight = new THREE.AmbientLight(0xffffff, 0.7);
		scene.add(ambientLight);

		const directionalLight = new THREE.DirectionalLight(0xffffff, 1.2);
		directionalLight.position.set(5, 10, 5);
		directionalLight.castShadow = true;
		directionalLight.shadow.mapSize.width = 4096;
		directionalLight.shadow.mapSize.height = 4096;
		directionalLight.shadow.camera.near = 0.1;
		directionalLight.shadow.camera.far = 50;
		directionalLight.shadow.camera.left = -10;
		directionalLight.shadow.camera.right = 10;
		directionalLight.shadow.camera.top = 10;
		directionalLight.shadow.camera.bottom = -10;
		directionalLight.shadow.bias = -0.001;
		scene.add(directionalLight);

		const fillLight = new THREE.DirectionalLight(0xffffff, 0.4);
		fillLight.position.set(-5, 5, -5);
		scene.add(fillLight);

		// Root group for the entire model (for rotation/scale/centering)
		modelGroup = new THREE.Group();
		modelGroup.rotation.y = CAMERA_ANGLE;
		scene.add(modelGroup);

		loadModel();

		window.addEventListener("resize", onWindowResize);
		renderer.domElement.addEventListener("pointerdown", onCanvasPointerDown);
		renderer.domElement.addEventListener("click", onCanvasClick);
		renderer.domElement.addEventListener("pointermove", onCanvasPointerMove);
		animate();
	};

	/** Re-parent a mesh into target, preserving its current world transform. */
	const attachWithWorldTransform = (mesh: THREE.Mesh, target: THREE.Object3D) => {
		mesh.updateWorldMatrix(true, false);
		const wp = new THREE.Vector3();
		const wq = new THREE.Quaternion();
		const ws = new THREE.Vector3();
		mesh.matrixWorld.decompose(wp, wq, ws);
		target.add(mesh);
		mesh.position.copy(wp);
		mesh.quaternion.copy(wq);
		mesh.scale.copy(ws);
	};

	const loadModel = () => {
		const loader = new GLTFLoader();
		loader.load(
			MODEL_PATH,
			gltf => {
				// Collect meshes per floor/shared first, then re-parent after traverse
				const buckets = new Map<string, THREE.Mesh[]>();
				FLOOR_IDS.forEach(fid => buckets.set(fid, []));
				const sharedBucket: THREE.Mesh[] = [];

				// Force world matrices to be up to date before we read them
				gltf.scene.updateMatrixWorld(true);

				gltf.scene.traverse(obj => {
					if (!(obj instanceof THREE.Mesh)) return;
					obj.castShadow = true;
					obj.receiveShadow = true;
					// Clone materials so opacity changes on one mesh don't affect others sharing the same material
					if (obj.material) {
						if (Array.isArray(obj.material)) {
							obj.material = obj.material.map(mat => {
								const m = mat.clone();
								m.transparent = true;
								m.opacity = 1;
								return m;
							});
						} else {
							obj.material = obj.material.clone();
							obj.material.transparent = true;
							obj.material.opacity = 1;
						}
					}
					const n = obj.name.toLowerCase();
					const matchedFloor = FLOOR_IDS.find(fid => n.startsWith(`floor__${fid}__`));
					const isShared = SHARED_NAMES.some(sn => n.startsWith(`floor__${sn}__`));
					if (matchedFloor) buckets.get(matchedFloor)!.push(obj);
					else if (isShared) sharedBucket.push(obj);
				});

				// Create one pivot Object3D per floor + one for shared, all under modelGroup
				FLOOR_IDS.forEach(fid => {
					const pivot = new THREE.Object3D();
					pivot.name = `pivot_${fid}`;
					modelGroup.add(pivot);
					floorPivots.set(fid, pivot);
				});

				sharedPivot = new THREE.Object3D();
				sharedPivot.name = "pivot_shared";
				modelGroup.add(sharedPivot);

				// Re-parent meshes into their pivot with baked world transforms
				buckets.forEach((meshes, fid) => {
					const pivot = floorPivots.get(fid)!;
					meshes.forEach(m => attachWithWorldTransform(m, pivot));
				});
				sharedBucket.forEach(m => attachWithWorldTransform(m, sharedPivot));

				console.log("Floors:", [...floorPivots.entries()].map(([k, v]) => `${k}(${v.children.length})`).join(", "), "| shared:", sharedPivot.children.length);

				centerAndScaleModel();
				buildMeshIndex();
				showAllFloorsCollapsed();
			},
			undefined,
			error => console.error("Error loading model:", error)
		);
	};

	const centerAndScaleModel = () => {
		// Temporarily add all pivots to measure total bounding box
		const box = new THREE.Box3().setFromObject(modelGroup);
		const center = box.getCenter(new THREE.Vector3());
		const size = box.getSize(new THREE.Vector3());

		modelGroup.position.x = -center.x + 2;
		modelGroup.position.z = -center.z;

		const maxDim = Math.max(size.x, size.y, size.z);
		modelGroup.scale.setScalar(8 / maxDim);

		// FLOOR_GAP_LOCAL is in pivot local space (pivots are direct children of modelGroup)
		// modelGroup scale is 8/maxDim, so 1 local unit = (8/maxDim) world units
		// We want ~2 world units gap → local gap = 2 / (8/maxDim) = maxDim/4
		FLOOR_GAP_LOCAL = maxDim / 4;
	};

	const setPivotOpacity = (pivot: THREE.Object3D, opacity: number, duration: number, onComplete?: () => void) => {
		const meshes: THREE.Mesh[] = [];
		pivot.traverse(c => {
			if (c instanceof THREE.Mesh && c.material) meshes.push(c);
		});
		meshes.forEach((mesh, i) => {
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (!("opacity" in mat)) return;
				gsap.killTweensOf(mat);
				if (duration === 0) {
					(mat as THREE.MeshStandardMaterial).opacity = opacity;
				} else {
					gsap.to(mat, {
						opacity,
						duration,
						onComplete: onComplete && i === meshes.length - 1 ? onComplete : undefined
					});
				}
			});
		});
		if (duration === 0 && onComplete) onComplete();
	};

	const showAllFloorsCollapsed = () => {
		currentFloor = null;
		isExploded = false;
		const rm = prefersReducedMotion();

		floorPivots.forEach(pivot => {
			pivot.visible = true;
			gsap.killTweensOf(pivot.position);
			if (rm) pivot.position.y = 0;
			else gsap.to(pivot.position, { y: 0, duration: 0.8, ease: "power2.inOut" });
			setPivotOpacity(pivot, 1, rm ? 0 : 0.5);
		});

		sharedPivot.visible = true;
		gsap.killTweensOf(sharedPivot.position);
		if (rm) sharedPivot.position.y = 0;
		else gsap.to(sharedPivot.position, { y: 0, duration: 0.8, ease: "power2.inOut" });
		setPivotOpacity(sharedPivot, 1, rm ? 0 : 0.5);

		if (rm) {
			camera.position.set(-8, 6, 8);
			controls.target.set(0, 1.5, 0);
		} else {
			gsap.to(camera.position, { x: -8, y: 6, z: 8, duration: 1, ease: "power2.inOut" });
			gsap.to(controls.target, { x: 0, y: 1.5, z: 0, duration: 1, ease: "power2.inOut" });
		}
	};

	const showAllFloorsStacked = () => {
		currentFloor = null;
		isExploded = true;
		const rm = prefersReducedMotion();

		floorPivots.forEach((pivot, fid) => {
			const yOffset = FLOOR_IDS.indexOf(fid) * FLOOR_GAP_LOCAL;
			pivot.visible = true;
			gsap.killTweensOf(pivot.position);
			if (rm) {
				pivot.position.y = yOffset;
			} else {
				gsap.to(pivot.position, { y: yOffset, duration: 0.8, ease: "power2.inOut" });
			}
			setPivotOpacity(pivot, 1, rm ? 0 : 0.5);
		});

		// Hide shared (elevators/outside) in exploded view — they'd look weird floating
		setPivotOpacity(sharedPivot, 0, rm ? 0 : 0.4, () => {
			sharedPivot.visible = false;
		});
		if (rm) sharedPivot.visible = false;

		if (rm) {
			camera.position.set(-8, 10, 10);
			controls.target.set(0, 2, 0);
		} else {
			gsap.to(camera.position, { x: -8, y: 10, z: 10, duration: 1, ease: "power2.inOut" });
			gsap.to(controls.target, { x: 0, y: 2, z: 0, duration: 1, ease: "power2.inOut" });
		}
	};

	const showSingleFloor = (floorId: string) => {
		const normalizedId = floorId.toLowerCase();
		currentFloor = normalizedId;
		const floorIndex = FLOOR_IDS.indexOf(normalizedId);
		const rm = prefersReducedMotion();

		floorPivots.forEach((pivot, fid) => {
			gsap.killTweensOf(pivot.position);
			if (fid === normalizedId) {
				pivot.visible = true;
				if (rm) pivot.position.y = 0;
				else gsap.to(pivot.position, { y: 0, duration: 0.6, ease: "power2.inOut" });
				setPivotOpacity(pivot, 1, rm ? 0 : 0.4);
			} else {
				setPivotOpacity(pivot, 0, rm ? 0 : 0.3, () => {
					pivot.visible = false;
				});
				if (rm) pivot.visible = false;
			}
		});

		// Hide shared on single-floor view
		setPivotOpacity(sharedPivot, 0, rm ? 0 : 0.3, () => {
			sharedPivot.visible = false;
		});
		if (rm) sharedPivot.visible = false;

		const cameraY = 4 + floorIndex * 0.3;
		if (rm) {
			camera.position.set(-6, cameraY, 6);
			controls.target.set(0, 0.5, 0);
		} else {
			gsap.to(camera.position, { x: -6, y: cameraY, z: 6, duration: 1, ease: "power2.inOut" });
			gsap.to(controls.target, { x: 0, y: 0.5, z: 0, duration: 1, ease: "power2.inOut" });
		}
	};

	const buildMeshIndex = () => {
		modelGroup.traverse(obj => {
			if (obj instanceof THREE.Mesh) meshByName.set(obj.name.toLowerCase(), obj);
		});
	};

	// ── Hover state ──────────────────────────────────────────────────────────
	let hoveredMesh: THREE.Mesh | null = null;
	// Meshes currently tinted by hover (may be a whole floor pivot's meshes)
	const hoveredMeshOriginals = new Map<THREE.Mesh, THREE.Color>();
	const HOVER_COLOR = new THREE.Color(0xffffff);

	const applyHoverTint = (meshes: THREE.Mesh[]) => {
		meshes.forEach(mesh => {
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (mat instanceof THREE.MeshStandardMaterial && !highlightedMeshes.has(mesh.name.toLowerCase())) {
					hoveredMeshOriginals.set(mesh, mat.emissive.clone());
					mat.emissive.copy(HOVER_COLOR);
					mat.emissiveIntensity = 0.15;
				}
			});
		});
	};

	const clearHoverTint = () => {
		hoveredMeshOriginals.forEach((originalEmissive, mesh) => {
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (mat instanceof THREE.MeshStandardMaterial && !highlightedMeshes.has(mesh.name.toLowerCase())) {
					mat.emissive.copy(originalEmissive);
					mat.emissiveIntensity = 0;
				}
			});
		});
		hoveredMeshOriginals.clear();
	};

	let hoveredFloorId: string | null = null;

	const setMeshHover = (mesh: THREE.Mesh | null, floorId?: string | null) => {
		const nextFloor = floorId ?? null;
		// Skip if nothing changed
		if (mesh === hoveredMesh && nextFloor === hoveredFloorId) return;
		clearHoverTint();
		hoveredFloorId = nextFloor;
		hoveredMesh = mesh;

		if (floorId) {
			// Highlight all meshes of the floor pivot
			const pivot = floorPivots.get(floorId);
			if (pivot) {
				const meshes: THREE.Mesh[] = [];
				pivot.traverse(c => {
					if (c instanceof THREE.Mesh) meshes.push(c);
				});
				applyHoverTint(meshes);
			}
		} else if (mesh) {
			applyHoverTint([mesh]);
		}
	};

	/** Get the floor ID a mesh belongs to based on its name prefix. */
	const getFloorIdFromMesh = (mesh: THREE.Mesh): string | null => {
		const n = mesh.name.toLowerCase();
		return FLOOR_IDS.find(fid => n.startsWith(`floor__${fid}__`)) ?? null;
	};

	/** Pick the topmost visible mesh under the pointer. */
	const pickMesh = (event: MouseEvent | PointerEvent): THREE.Mesh | null => {
		const canvas = renderer.domElement;
		const rect = canvas.getBoundingClientRect();
		mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
		mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
		raycaster.setFromCamera(mouse, camera);
		const hits = raycaster.intersectObject(modelGroup, true);
		for (const hit of hits) {
			if (hit.object instanceof THREE.Mesh) return hit.object;
		}
		return null;
	};

	const zoomToMeshes = (names: string[]) => {
		const box = new THREE.Box3();
		names.forEach(rawName => {
			const mesh = meshByName.get(rawName.toLowerCase());
			if (mesh) box.expandByObject(mesh);
		});
		if (box.isEmpty()) return;
		const center = box.getCenter(new THREE.Vector3());
		const size = box.getSize(new THREE.Vector3());
		const maxDim = Math.max(size.x, size.y, size.z);
		// Position camera so object fills view nicely
		const fov = camera.fov * (Math.PI / 180);
		const dist = (maxDim / 2 / Math.tan(fov / 2)) * 2.2;
		const offset = new THREE.Vector3(-dist * 0.6, dist * 0.5, dist * 0.8).normalize().multiplyScalar(dist);
		const rm = prefersReducedMotion();
		if (rm) {
			camera.position.copy(center).add(offset);
			controls.target.copy(center);
		} else {
			gsap.to(camera.position, { x: center.x + offset.x, y: center.y + offset.y, z: center.z + offset.z, duration: 0.8, ease: "power2.inOut" });
			gsap.to(controls.target, { x: center.x, y: center.y, z: center.z, duration: 0.8, ease: "power2.inOut" });
		}
	};

	/** Called by the UI's room-item click to also zoom the camera. */
	const selectRoomItem = (meshNames: string[]) => {
		highlightMeshes(meshNames);
		zoomToMeshes(meshNames);
	};

	// Track pointer-down position to distinguish click from drag
	let pointerDownX = 0;
	let pointerDownY = 0;
	const onCanvasPointerDown = (e: PointerEvent) => {
		pointerDownX = e.clientX;
		pointerDownY = e.clientY;
	};

	/** Fired when the canvas is clicked. */
	const onCanvasClick = (event: MouseEvent) => {
		// Ignore if pointer moved more than 5px (orbit drag)
		if (Math.hypot(event.clientX - pointerDownX, event.clientY - pointerDownY) > 5) return;
		// No interaction when on the floor-selection overview (not exploded, no floor selected)
		if (!isExploded && !currentFloor) return;

		const mesh = pickMesh(event);
		if (!mesh) return;

		if (isExploded && !currentFloor) {
			// ── Layered view: clicking a floor navigates into it ──
			const floorId = getFloorIdFromMesh(mesh);
			if (floorId) {
				// Mimic clicking the floor button
				const floorBtn = document.querySelector(`.floor-btn[data-floor="${floorId}"]`) as HTMLElement | null;
				floorBtn?.click();
			}
			return;
		}

		if (currentFloor) {
			// ── Single-floor view: clicking a mesh selects it ──
			const n = mesh.name.toLowerCase();
			// Find matching room item by checking its data-meshes list
			const roomItems = document.querySelectorAll(".room-item");
			let matched: Element | null = null;
			roomItems.forEach(el => {
				const raw = el.getAttribute("data-meshes");
				if (!raw) return;
				const names: string[] = JSON.parse(raw);
				if (names.map(s => s.toLowerCase()).includes(n)) matched = el;
			});

			if (matched) {
				// Toggle or select
				const firstMesh = JSON.parse((matched as Element).getAttribute("data-meshes")!)[0]?.toLowerCase();
				if (firstMesh && highlightedMeshes.has(firstMesh)) {
					clearHighlight();
					document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
					return;
				}
				clearHighlight();
				document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
				(matched as Element).classList.add("active");
				const meshNames: string[] = JSON.parse((matched as Element).getAttribute("data-meshes")!);
				selectRoomItem(meshNames);
				// Scroll matched item into view in sidebar
				(matched as HTMLElement).scrollIntoView({ behavior: "smooth", block: "nearest" });
			}
		}
	};

	/** Fired on pointer move for hover effect. */
	const onCanvasPointerMove = (event: PointerEvent) => {
		// No interaction when on the floor-selection overview
		if (!isExploded && !currentFloor) {
			renderer.domElement.style.cursor = "grab";
			setMeshHover(null, null);
			return;
		}

		const mesh = pickMesh(event as unknown as MouseEvent);

		if (isExploded && !currentFloor) {
			// Highlight the entire floor on hover
			const floorId = mesh ? getFloorIdFromMesh(mesh) : null;
			renderer.domElement.style.cursor = floorId ? "pointer" : "grab";
			setMeshHover(mesh, floorId);
			return;
		}

		if (currentFloor) {
			// Only highlight meshes that belong to a room item
			let actionable = false;
			if (mesh) {
				const n = mesh.name.toLowerCase();
				document.querySelectorAll(".room-item").forEach(el => {
					const raw = el.getAttribute("data-meshes");
					if (!raw) return;
					const names: string[] = JSON.parse(raw);
					if (names.map(s => s.toLowerCase()).includes(n)) actionable = true;
				});
			}
			renderer.domElement.style.cursor = actionable ? "pointer" : "grab";
			setMeshHover(actionable ? mesh : null, null);
		}
	};

	const clearHighlight = () => {
		highlightedMeshes.forEach((originalColor, meshName) => {
			const mesh = meshByName.get(meshName);
			if (!mesh) return;
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (mat instanceof THREE.MeshStandardMaterial) {
					gsap.killTweensOf(mat.emissive);
					gsap.killTweensOf(mat);
					mat.emissive.copy(originalColor);
					mat.emissiveIntensity = 0;
				}
			});
		});
		highlightedMeshes.clear();
	};

	const highlightMeshes = (names: string[]) => {
		clearHighlight();
		names.forEach(rawName => {
			const name = rawName.toLowerCase();
			const mesh = meshByName.get(name);
			if (!mesh) return;
			const mats = Array.isArray(mesh.material) ? mesh.material : [mesh.material];
			mats.forEach((mat: THREE.Material) => {
				if (!(mat instanceof THREE.MeshStandardMaterial)) return;
				// Save original emissive before first highlight
				if (!highlightedMeshes.has(name)) {
					highlightedMeshes.set(name, mat.emissive.clone());
				}
				mat.emissive.copy(HIGHLIGHT_COLOR);
				// Pulse emissive intensity
				gsap.killTweensOf(mat);
				gsap.fromTo(
					mat,
					{ emissiveIntensity: 0 },
					{
						emissiveIntensity: HIGHLIGHT_EMISSIVE_INTENSITY,
						duration: 0.4,
						ease: "power2.out",
						yoyo: true,
						repeat: -1,
						repeatDelay: 0.3
					}
				);
			});
		});
	};

	const onWindowResize = () => {
		const canvas = document.getElementById("venue-canvas") as HTMLCanvasElement;
		if (!canvas) return;
		const canvasRect = canvas.getBoundingClientRect();
		camera.aspect = canvasRect.width / canvasRect.height;
		camera.updateProjectionMatrix();
		renderer.setSize(canvasRect.width, canvasRect.height);
	};

	const animate = () => {
		animationId = requestAnimationFrame(animate);
		controls.update();
		renderer.render(scene, camera);
	};

	const cleanup = () => {
		if (animationId) cancelAnimationFrame(animationId);
		window.removeEventListener("resize", onWindowResize);
		renderer?.domElement.removeEventListener("pointerdown", onCanvasPointerDown);
		renderer?.domElement.removeEventListener("click", onCanvasClick);
		renderer?.domElement.removeEventListener("pointermove", onCanvasPointerMove);

		modelGroup?.traverse((child: THREE.Object3D) => {
			if (child instanceof THREE.Mesh) {
				child.geometry?.dispose();
				const mats = Array.isArray(child.material) ? child.material : [child.material];
				mats.forEach((m: THREE.Material) => m.dispose());
			}
		});

		floorPivots.clear();
		meshByName.clear();
		highlightedMeshes.clear();
		renderer?.dispose();
		controls?.dispose();
	};

	const initVenue = () => {
		const floorSelection = document.getElementById("floor-selection");
		const advancedMenu = document.getElementById("advanced-menu");
		const backBtn = document.getElementById("back-btn");
		const floorBtns = document.querySelectorAll(".floor-btn");
		const roomListContainers = document.querySelectorAll(".room-list-container");
		const hint = document.querySelector(".hint");

		if (!floorSelection || !advancedMenu || !backBtn) return;

		// Initial state for floor buttons
		gsap.set(".floor-btn", { opacity: 1, y: 0 });
		if (hint) gsap.set(hint, { opacity: 0.9, y: 0 });

		floorBtns.forEach(btn => {
			btn.addEventListener("click", () => {
				const floorId = btn.getAttribute("data-floor");
				if (floorId) showFloor(floorId);
			});
		});

		const explodeToggleBtn = document.getElementById("explode-toggle-btn");
		if (explodeToggleBtn) {
			explodeToggleBtn.addEventListener("click", () => {
				if (isExploded) {
					showAllFloorsCollapsed();
					explodeToggleBtn.classList.remove("active");
				} else {
					showAllFloorsStacked();
					explodeToggleBtn.classList.add("active");
				}
			});
		}

		backBtn.addEventListener("click", () => {
			clearHighlight();
			showSelection();
		});

		// Room item highlight on click
		document.querySelectorAll(".room-item").forEach(el => {
			el.addEventListener("click", () => {
				const raw = el.getAttribute("data-meshes");
				if (!raw) return;
				const meshNames: string[] = JSON.parse(raw);

				// Toggle off if already highlighted
				const firstMesh = meshNames[0]?.toLowerCase();
				if (firstMesh && highlightedMeshes.has(firstMesh)) {
					clearHighlight();
					document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
					return;
				}

				clearHighlight();
				document.querySelectorAll(".room-item.active").forEach(e => e.classList.remove("active"));
				el.classList.add("active");
				selectRoomItem(meshNames);
			});
		});

		const showFloor = (floorId: string) => {
			const targetRoomList = document.getElementById(`room-list-${floorId}`);
			if (!targetRoomList) return;

			// Update 3D view
			showSingleFloor(floorId);

			const tl = gsap.timeline();

			// 1. Exit Floor Selection
			tl.to(".floor-btn", {
				opacity: 0,
				y: 20,
				duration: 0.3,
				stagger: 0.05,
				ease: "power2.in"
			});
			if (hint) {
				tl.to(hint, { opacity: 0, y: 10, duration: 0.2 }, "<");
			}

			tl.add(() => {
				floorSelection?.classList.add("hidden");
				advancedMenu?.classList.remove("hidden");
				roomListContainers.forEach(container => container.classList.add("hidden"));
				targetRoomList.classList.remove("hidden");
			});

			// 2. Enter Advanced Menu
			tl.fromTo("#back-btn", { opacity: 0, x: -10 }, { opacity: 1, x: 0, duration: 0.4, ease: "power2.out" });

			tl.fromTo(
				targetRoomList.querySelectorAll(".room-item-wrapper"),
				{ opacity: 0, y: 30 },
				{
					opacity: 1,
					y: 0,
					duration: 0.5,
					stagger: 0.1,
					ease: "power2.out"
				},
				"-=0.3"
			);
		};

		const showSelection = () => {
			const activeRoomList = Array.from(roomListContainers).find(c => !c.classList.contains("hidden"));
			if (!activeRoomList) return;

			// Update 3D view — return to whichever overview mode was active
			if (isExploded) showAllFloorsStacked();
			else showAllFloorsCollapsed();

			const tl = gsap.timeline();

			// 1. Exit Advanced Menu
			tl.to(activeRoomList.querySelectorAll(".room-item-wrapper"), {
				opacity: 0,
				y: 30,
				duration: 0.3,
				stagger: {
					each: 0.05,
					from: "end"
				},
				ease: "power2.in"
			});

			tl.to("#back-btn", { opacity: 0, x: -10, duration: 0.2 }, "<");

			tl.add(() => {
				advancedMenu?.classList.add("hidden");
				floorSelection?.classList.remove("hidden");
			});

			// 2. Enter Floor Selection
			tl.fromTo(
				".floor-btn",
				{ opacity: 0, y: 20 },
				{
					opacity: 1,
					y: 0,
					duration: 0.4,
					stagger: 0.1,
					ease: "power2.out"
				}
			);
			if (hint) {
				tl.fromTo(hint, { opacity: 0, y: 10 }, { opacity: 0.9, y: 0, duration: 0.3 }, "-=0.2");
			}
		};
	};

	// Initialize Three.js
	initThree();

	// Run on initial load
	initVenue();

	// Run on View Transitions navigation
	document.addEventListener("astro:after-swap", () => {
		cleanup();
		initThree();
		initVenue();
	});

	// Cleanup on page unload
	document.addEventListener("astro:before-swap", cleanup);
</script>
