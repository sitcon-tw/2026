---
import Footer from "@/components/Footer.astro";
import Layout from "@/layout/Layout.astro";
import { type Lang, useTranslations } from "@/utils/i18n";

const lang = (Astro.props.lang ?? "zh") as Lang;
const t = useTranslations(lang).about;
const title = Astro.props.title ?? (lang === "en" ? `${t.title} - SITCON 2026` : `${t.title} - SITCON 2026`);
const description = Astro.props.description ?? (lang === "en" ? t.description : t.description);
---

<Layout lang={lang} title={title} description={description}>
	<main class="about-page">
		<section class="about-hero">
			<div class="about-hero-copy">
				<p class="metal-eyebrow text-reveal-paragraph">SITCON</p>
				<h1 class="metal-page-title text-reveal-title">{t.title}</h1>
				<p class="about-description metal-copy text-reveal-paragraph">{t.description}</p>
			</div>
			<figure class="about-hero-media">
				<img src="/2026/img/about/sitcon-2025.webp" alt="SITCON 2025" width="1200" height="675" fetchpriority="high" />
			</figure>
		</section>
		<section class="community-section">
			<div class="section-heading">
				<p class="metal-eyebrow text-reveal-paragraph">Community</p>
				<h2 class="section-title text-reveal-title">{t.community.title}</h2>
			</div>
			<div class="community-data-container" aria-label={t.community.title}>
				{
					t.community.data.map(item => (
						<div class="community-item">
							<span class="community-count text-reveal-title">{item.count}</span>
							<span class="community-label">{item.label}</span>
						</div>
					))
				}
			</div>
		</section>
		<section class="history-section">
			<div class="section-heading">
				<p class="metal-eyebrow text-reveal-paragraph">Impact</p>
				<h2 class="section-title text-reveal-title">{t.history.title}</h2>
			</div>
			<div class="history-container">
				{
					t.history.data.map(item => (
						<div class="history-item">
							<img src={`/2026/img/about/${item.image}.webp`} alt={item.title} class="history-image" width="640" height="420" loading="lazy" />
							<div class="history-content">
								<h3>{item.title}</h3>
								<p>{item.description}</p>
							</div>
						</div>
					))
				}
			</div>
		</section>
		<section class="media-section">
			<div class="section-heading">
				<p class="metal-eyebrow text-reveal-paragraph">Press</p>
				<h2 class="section-title text-reveal-title">{t.media.title}</h2>
			</div>
			<div class="media-container">
				{
					t.media.items.map(item => (
						<a href={item.url} target="_blank" rel="noopener noreferrer" class="media-item">
							<img src={`/2026/img/about/${item.image}.webp`} alt={item.alt} width="520" height="300" loading="lazy" />
							<span>{item.alt}</span>
						</a>
					))
				}
			</div>
		</section>
		<section class="recap-section">
			<div class="section-heading">
				<p class="metal-eyebrow text-reveal-paragraph">Review</p>
				<h2 class="section-title text-reveal-title">{t.recap.title}</h2>
			</div>
			<div class="recap-stats">
				{
					t.recap.stats.map(stat => (
						<div class="recap-stat">
							<span class="recap-number text-reveal-title">{stat.number}</span>
							<span class="recap-label">{stat.label}</span>
						</div>
					))
				}
			</div>
			<div class="recap-charts">
				<div class="recap-chart-item">
					<h3 class="chart-title text-reveal-title">{t.recap.charts[0].title}</h3>
					<div id="attender-role-chart" class="chart-canvas" data-chart={JSON.stringify(t.recap.charts[0].data)}></div>
				</div>
				<div class="recap-chart-item">
					<h3 class="chart-title text-reveal-title">{t.recap.charts[1].title}</h3>
					<div id="programming-level-chart" class="chart-canvas" data-chart={JSON.stringify(t.recap.charts[1].data)}></div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	main {
		max-width: 60rem;
		margin: 0 auto;
		margin-bottom: 3rem;
		padding: 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 4rem;
	}

	.wavy-spacer {
		height: 20px;
		width: 100%;
		background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 4" fill="none" stroke="%23E8BB5F" stroke-width="1"><path d="M0 3.5c5 0 5-3 10-3s5 3 10 3 5-3 10-3 5 3 10 3"/></svg>');
		background-repeat: repeat-x;
		background-size: 40px 10px;
		background-position: 0 0;
		margin-bottom: 2rem;
		animation: wave-scroll 4s linear infinite;
	}

	@keyframes wave-scroll {
		0% {
			background-position: 0 0;
		}
		100% {
			background-position: 40px 0;
		}
	}

	.about-header {
		margin-top: 8rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.header-img {
		border-radius: 0.5rem;
		object-fit: cover;
		height: 20rem;
		margin-bottom: 1rem;
		box-shadow: var(--metal-card-shadow);
	}

	/* Community Section */
	.community-section {
		text-align: center;
	}

	.section-title {
		font-weight: bold;
		text-align: center;
		font-size: 2rem;
		margin-bottom: 2rem;
	}

	.community-data-container {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.community-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		flex: 1 1 15rem;
		min-width: 15rem;
	}

	.community-item:last-child {
		grid-column: 1 / -1;
	}

	.community-item {
		background: rgba(255, 244, 214, 0.88);
		border: 1px solid rgba(242, 216, 148, 0.34);
		border-radius: 0.5rem;
		padding: 1rem;
		box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.16);
		color: #3c2d0e;
	}

	.community-item .community-count {
		font-size: 2.5rem;
		font-weight: bold;
		margin-bottom: 0;
		color: var(--metal-bronze);
	}

	.community-item .community-label {
		font-size: 1rem;
	}

	/* Review Section */
	.recap-section {
		text-align: center;
		margin: 2rem 0;
	}

	.recap-stats {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
	}

	@media (max-width: 60rem) {
		.recap-stats {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 30rem) {
		.recap-stats {
			grid-template-columns: 1fr;
		}
	}

	.recap-stat {
		background: var(--metal-surface-strong);
		border: 1px solid var(--metal-line);
		border-radius: 0.5rem;
		padding: 1.5rem 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		box-shadow: var(--metal-card-shadow);
	}

	.recap-number {
		font-size: 2.5rem;
		font-weight: bold;
		color: var(--metal-gold-soft);
		line-height: 1;
	}

	/* Recap Chart */
	.recap-charts {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-top: 1rem;
	}

	@media (max-width: 50rem) {
		.recap-charts {
			grid-template-columns: 1fr;
		}
	}

	.recap-chart-item {
		background: var(--metal-surface-strong);
		border: 1px solid var(--metal-line);
		border-radius: 0.5rem;
		padding: 1.5rem;
		box-shadow: var(--metal-card-shadow);
	}

	.chart-title {
		margin-bottom: 1rem;
	}

	.chart-canvas {
		width: 100%;
		height: 280px;
	}

	/* Things Section */
	.history-container {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
		gap: 1rem;
	}

	.history-item:last-child {
		grid-column: 1 / -1;
	}

	.history-item {
		position: relative;
		border-radius: 0.5rem;
		overflow: hidden;
		height: 15rem;
		box-shadow: var(--metal-card-shadow);
	}

	.history-image {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.history-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.3) 60%, transparent 100%);
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		padding: 0.5rem 1.5rem;
		color: #ffffff;
	}

	.history-overlay::before {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.3) 60%, transparent 100%);
		color: #ffffff;
		transition: opacity 0.3s ease;
		opacity: 0;
		content: "";
	}

	.history-item:hover .history-overlay::before {
		opacity: 1;
	}

	.history-overlay h3 {
		font-size: 1.3rem;
		font-weight: bold;
		margin-bottom: 0.5rem;
		z-index: 2;
	}

	.history-overlay p {
		font-size: 0.85rem;
		line-height: 1.5;
		opacity: 0.8;
		z-index: 2;
	}

	/* Media Section */
	.media-section {
		text-align: center;
	}

	.media-container {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1rem;
	}

	@media (max-width: 45rem) {
		.media-container {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 30rem) {
		.media-container {
			grid-template-columns: 1fr;
		}
	}

	.media-item {
		position: relative;
		display: block;
		border-radius: 0.5rem;
		overflow: hidden;
		transition:
			box-shadow 0.3s ease,
			transform 0.3s ease;
		box-shadow: 0 1rem 2rem rgba(0, 0, 0, 0.16);
	}

	.media-item:hover {
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
		transform: translateY(-2px);
	}

	.media-item img {
		height: 10rem;
		width: 100%;
		object-position: top;
		object-fit: cover;
		display: block;
		transition: filter 0.5s ease;
	}

	.media-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.75) 0%, rgba(0, 0, 0, 0.1) 60%, transparent 100%);
		display: flex;
		align-items: flex-end;
		text-align: left;
		padding: 1rem;
		color: #ffffff;
		font-size: 0.85rem;
		line-height: 1.5;
		opacity: 0;
		transition: opacity 0.5s ease;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
	}

	.media-item:hover .media-overlay {
		opacity: 1;
	}

	main.about-page {
		max-width: none;
		margin: 0;
		padding: 0;
		gap: 0;
		color: var(--metal-cream);
		background: var(--metal-bg);
	}

	.about-hero,
	.community-section,
	.history-section,
	.media-section,
	.recap-section {
		padding: var(--section-padding);
	}

	.about-hero {
		min-height: 100svh;
		display: grid;
		grid-template-columns: minmax(0, 0.85fr) minmax(20rem, 1.15fr);
		align-items: center;
		gap: clamp(2rem, 6vw, 7rem);
		max-width: 92rem;
		margin-inline: auto;
		padding-top: clamp(7rem, 12vw, 10rem);
	}

	.about-hero-copy {
		display: flex;
		flex-direction: column;
		gap: 1.35rem;
	}

	.about-description {
		max-width: 42rem;
		font-size: clamp(1.05rem, 1.6vw, 1.25rem);
		margin: 0;
	}

	.about-hero-media {
		margin: 0;
		position: relative;
		overflow: hidden;
		border-radius: var(--metal-radius);
		border: 1px solid rgba(242, 216, 148, 0.28);
		background: var(--metal-glass);
		box-shadow: var(--metal-card-shadow);
	}

	.about-hero-media::after {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(120deg, rgba(255, 246, 220, 0.12), transparent 44%), linear-gradient(0deg, rgba(20, 19, 15, 0.28), transparent 50%);
		pointer-events: none;
	}

	.about-hero-media img {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 10;
		height: auto;
		object-fit: cover;
	}

	.section-heading {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 72rem;
		margin: 0 auto clamp(2rem, 5vw, 3.5rem);
	}

	.section-title {
		text-align: left;
		font-size: clamp(2.4rem, 5vw, 4.5rem);
		line-height: 1.05;
		margin: 0;
		color: inherit;
	}

	.community-section,
	.media-section {
		background: var(--metal-light-bg);
		color: var(--coffee);
	}

	.community-section .metal-eyebrow,
	.media-section .metal-eyebrow {
		color: var(--metal-bronze);
	}

	.community-data-container {
		display: grid;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 1rem;
		max-width: 72rem;
		margin-inline: auto;
	}

	.community-item {
		min-width: 0;
		grid-column: span 2;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--metal-light-line);
		border-radius: var(--metal-radius);
		padding: clamp(1.25rem, 3vw, 2rem);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.76),
			0 1rem 2.5rem rgba(45, 33, 17, 0.08);
		align-items: flex-start;
	}

	.community-item:nth-last-child(-n + 2) {
		grid-column: span 3;
	}

	.community-item .community-count {
		font-family: "JetBrainsMono", monospace;
		font-size: clamp(2.5rem, 6vw, 4.5rem);
		color: var(--metal-bronze);
		letter-spacing: 0;
	}

	.community-item .community-label {
		font-size: 1rem;
		color: rgba(45, 33, 17, 0.76);
	}

	.history-section,
	.recap-section {
		background: radial-gradient(circle at 85% 8%, rgba(242, 216, 148, 0.12), transparent 28rem), linear-gradient(180deg, rgba(20, 19, 15, 0.98), rgba(36, 35, 31, 0.96));
		color: var(--metal-cream);
	}

	.history-container {
		max-width: 72rem;
		margin-inline: auto;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		gap: 1rem;
	}

	.history-item,
	.history-item:last-child {
		grid-column: span 3;
		height: auto;
		min-height: 28rem;
		display: flex;
		flex-direction: column;
		background: linear-gradient(145deg, rgba(255, 244, 214, 0.12), rgba(20, 19, 15, 0.5));
		border: 1px solid var(--metal-line);
		border-radius: var(--metal-radius);
		box-shadow: var(--metal-card-shadow);
	}

	.history-item:first-child {
		grid-column: span 6;
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
		min-height: 24rem;
	}

	.history-image {
		position: static;
		width: 100%;
		height: 15rem;
		object-fit: cover;
	}

	.history-item:first-child .history-image {
		height: 100%;
		min-height: 24rem;
	}

	.history-content {
		padding: clamp(1.4rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.history-content h3 {
		font-size: clamp(1.35rem, 2.5vw, 2rem);
		line-height: 1.15;
		margin: 0;
		color: var(--metal-cream);
	}

	.history-content p {
		margin: 0;
		color: rgba(244, 239, 229, 0.74);
		line-height: 1.72;
	}

	.media-container {
		max-width: 72rem;
		margin-inline: auto;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.media-item {
		display: flex;
		flex-direction: column;
		background: rgba(255, 255, 255, 0.58);
		border: 1px solid var(--metal-light-line);
		box-shadow:
			inset 0 1px 0 rgba(255, 255, 255, 0.72),
			0 1rem 2.5rem rgba(45, 33, 17, 0.08);
		color: var(--coffee);
	}

	.media-item img {
		height: auto;
		aspect-ratio: 16 / 10;
	}

	.media-item span {
		padding: 1rem;
		font-size: 0.95rem;
		line-height: 1.5;
		text-align: left;
		color: rgba(45, 33, 17, 0.78);
	}

	.recap-section {
		text-align: left;
	}

	.recap-stats,
	.recap-charts {
		max-width: 72rem;
		margin-inline: auto;
	}

	.recap-stats {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.recap-stat,
	.recap-chart-item {
		background: linear-gradient(145deg, rgba(255, 244, 214, 0.12), rgba(20, 19, 15, 0.58));
		border: 1px solid var(--metal-line);
		border-radius: var(--metal-radius);
		box-shadow: var(--metal-card-shadow);
	}

	.recap-stat {
		align-items: flex-start;
		text-align: left;
	}

	.recap-number {
		font-family: "JetBrainsMono", monospace;
		font-size: clamp(2.25rem, 5vw, 3.75rem);
	}

	.recap-label {
		color: rgba(244, 239, 229, 0.74);
	}

	.recap-charts {
		gap: 1rem;
	}

	.chart-title {
		font-size: clamp(1.1rem, 2vw, 1.4rem);
		color: var(--metal-cream);
	}

	@media (max-width: 60rem) {
		.about-hero {
			grid-template-columns: 1fr;
			min-height: auto;
		}

		.about-hero-media {
			order: -1;
		}

		.community-data-container,
		.history-container,
		.media-container,
		.recap-stats {
			grid-template-columns: 1fr;
		}

		.community-item,
		.community-item:nth-last-child(-n + 2),
		.history-item,
		.history-item:first-child,
		.history-item:last-child {
			grid-column: auto;
		}

		.history-item:first-child {
			display: flex;
		}

		.history-item:first-child .history-image {
			height: 15rem;
			min-height: 0;
		}
	}

	@media (max-width: 45rem) {
		.about-hero,
		.community-section,
		.history-section,
		.media-section,
		.recap-section {
			padding-inline: 1rem;
		}

		.recap-charts {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	type EChartsApi = typeof import("echarts/core");
	type EChartsInstance = ReturnType<EChartsApi["init"]>;

	const charts = new Map<string, EChartsInstance>();
	let chartModulePromise: Promise<EChartsApi> | null = null;
	let chartObserver: IntersectionObserver | null = null;

	function getChartElements() {
		return Array.from(document.querySelectorAll<HTMLElement>(".chart-canvas[data-chart]"));
	}

	function parseChartData(element: HTMLElement) {
		try {
			const parsed = JSON.parse(element.dataset.chart ?? "[]");
			return Array.isArray(parsed) ? parsed : [];
		} catch {
			return [];
		}
	}

	function createChartOption(data: unknown[]) {
		const isMobile = window.innerWidth <= 768;

		return {
			tooltip: {
				trigger: "item",
				backgroundColor: "rgba(60, 45, 14, 0.95)",
				borderColor: "#e8bb5f",
				borderWidth: 1,
				textStyle: {
					color: "#fff8e7"
				},
				formatter: "{b}: {c} ({d}%)"
			},
			legend: {
				orient: isMobile ? "horizontal" : "vertical",
				left: isMobile ? "center" : "auto",
				right: isMobile ? "auto" : "5%",
				top: isMobile ? "bottom" : "center",
				textStyle: {
					color: "#f5dfa0",
					fontSize: isMobile ? 10 : 12
				},
				itemWidth: isMobile ? 15 : 25,
				itemHeight: isMobile ? 10 : 14
			},
			series: [
				{
					type: "pie",
					radius: ["40%", "70%"],
					center: isMobile ? ["50%", "35%"] : ["35%", "50%"],
					avoidLabelOverlap: true,
					itemStyle: {
						borderRadius: 10,
						borderColor: "#3c2d0e",
						borderWidth: 2
					},
					label: {
						show: false
					},
					emphasis: {
						label: {
							show: false
						}
					},
					labelLine: {
						show: false
					},
					data
				}
			],
			color: ["#e8bb5f", "#d1a348", "#c47c1a", "#a85e10", "#f5dfa0", "#f0ce7a", "#b8943c", "#8c6a1e", "#614a0e"]
		};
	}

	function loadECharts() {
		if (!chartModulePromise) {
			chartModulePromise = Promise.all([import("echarts/core"), import("echarts/charts"), import("echarts/components"), import("echarts/renderers")]).then(
				([echarts, { PieChart }, { TooltipComponent, LegendComponent }, { CanvasRenderer }]) => {
					echarts.use([PieChart, TooltipComponent, LegendComponent, CanvasRenderer]);
					return echarts;
				}
			);
		}
		return chartModulePromise;
	}

	async function renderChart(element: HTMLElement) {
		const echarts = await loadECharts();
		if (!element.isConnected) return;

		let chart = charts.get(element.id);
		if (!chart) {
			chart = echarts.init(element);
			charts.set(element.id, chart);
		}

		chart.setOption(createChartOption(parseChartData(element)), true);
	}

	function initCharts() {
		const chartElements = getChartElements();
		if (chartElements.length === 0) return;

		if (!("IntersectionObserver" in window)) {
			chartElements.forEach(element => {
				void renderChart(element);
			});
			return;
		}

		chartObserver?.disconnect();
		chartObserver = new IntersectionObserver(
			entries => {
				entries.forEach(entry => {
					if (!entry.isIntersecting) return;
					chartObserver?.unobserve(entry.target);
					void renderChart(entry.target as HTMLElement);
				});
			},
			{ rootMargin: "200px" }
		);

		chartElements.forEach(element => {
			if (!charts.has(element.id)) {
				chartObserver?.observe(element);
			}
		});
	}

	function refreshCharts() {
		getChartElements().forEach(element => {
			const chart = charts.get(element.id);
			if (!chart) return;
			chart.resize();
			chart.setOption(createChartOption(parseChartData(element)), true);
		});
	}

	function disposeCharts() {
		chartObserver?.disconnect();
		chartObserver = null;
		charts.forEach(chart => {
			chart.dispose();
		});
		charts.clear();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initCharts);
	} else {
		initCharts();
	}

	let resizeTimeout: ReturnType<typeof setTimeout>;
	window.addEventListener("resize", () => {
		clearTimeout(resizeTimeout);
		resizeTimeout = setTimeout(() => {
			refreshCharts();
		}, 250);
	});
	document.addEventListener("astro:page-load", initCharts);
	document.addEventListener("astro:before-swap", disposeCharts);
	window.addEventListener("pagehide", disposeCharts);
</script>
